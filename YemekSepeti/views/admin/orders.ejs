<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css?v=20260629-mobilefix1">
<link rel="stylesheet" href="/assets/css/pages/admin.css">
<link rel="stylesheet" href="/assets/css/pages/checkout.css">

<div class="panel-layout">

    <%- include('../partials/sidebar') %>

    <main class="panel-content">
        <h1 class="panel-title">Sipariş Yönetimi</h1>

        <div class="card">
            <div class="card-content">
                <!-- Durum filtreleri -->
                <div id="admin-order-filter-bar" style="display:flex;gap:0.5rem;margin-bottom:0.85rem;flex-wrap:wrap;">
                    <button type="button" class="btn btn-sm btn-primary"   data-group="all">Tümü</button>
                    <button type="button" class="btn btn-sm btn-secondary" data-group="beklemede">⏳ Beklemede</button>
                    <button type="button" class="btn btn-sm btn-secondary" data-group="hazir">✅ Hazır</button>
                    <button type="button" class="btn btn-sm btn-secondary" data-group="kuryede">🛵 Kuryede</button>
                    <button type="button" class="btn btn-sm btn-secondary" data-group="teslim">📦 Teslim Edildi</button>
                    <button type="button" class="btn btn-sm btn-secondary" data-group="iptal">✖ İptal</button>
                </div>

                <div class="form-group" style="margin-bottom:0.85rem;">
                    <input type="text" id="admin-order-search" class="form-input" placeholder="Sipariş numarası ile ara…">
                </div>

                <div id="admin-orders-list">
                    <p class="admin-empty-text">Siparişler yükleniyor…</p>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Sipariş detay / müdahale modalı -->
<div id="admin-order-modal" class="modal-overlay" style="display:none;">
    <div class="modal-content" style="max-width:560px;">
        <div class="card">
            <div class="card-content">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">
                    <h3 class="checkout-card-title" id="admin-order-modal-title" style="margin:0;">Sipariş Detayı</h3>
                    <button type="button" class="btn btn-sm btn-secondary" id="admin-order-modal-close" aria-label="Kapat">✕</button>
                </div>
                <div id="admin-order-modal-body"></div>
                <div id="admin-order-modal-footer" style="display:flex;flex-wrap:wrap;gap:0.5rem;justify-content:flex-end;margin-top:1rem;"></div>
            </div>
        </div>
    </div>
</div>

<style>
.modal-overlay { position: fixed; inset: 0; left: 0; right: 0; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; align-items: center; justify-content: center; padding: 1rem; }
.modal-overlay .modal-content { width: 100%; max-width: 560px; max-height: calc(100vh - 2rem); margin: 0 auto; position: relative; overflow-y: auto; }
.modal-overlay .card { margin: 0; }
.admin-order-card { border:1px solid var(--border-color); border-radius:10px; padding:0.85rem 1rem; margin-bottom:0.75rem; background:var(--card-bg); color:var(--text-color); }
.admin-order-card-head { display:flex; justify-content:space-between; align-items:center; gap:0.5rem; flex-wrap:wrap; }
.admin-order-badge { display:inline-block; padding:0.15rem 0.6rem; border-radius:999px; font-size:0.78rem; font-weight:600; }
.admin-order-meta { color:var(--text-color-light); font-size:0.87rem; margin-top:0.35rem; }
.admin-order-actions { display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:0.6rem; }
.admin-empty-text { color:var(--text-color-light); }
</style>
