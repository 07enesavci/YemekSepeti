<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css?v=20260629-mobilefix1">
<link rel="stylesheet" href="/assets/css/pages/admin.css">
<link rel="stylesheet" href="/assets/css/pages/checkout.css">

<div class="panel-layout">
    
    <%- include('../partials/sidebar') %>

    <main class="panel-content">
        <h1 class="panel-title">Kupon Yönetimi</h1>

        <div class="card">
            <div class="card-content">
                <h3 class="checkout-card-title">Yeni Kupon Kodu Oluştur</h3>
                
                <form id="coupon-form">
                    <div class="form-group">
                        <label for="coupon-code" class="form-label">Kupon Kodu *</label>
                        <input type="text" id="coupon-code" class="form-input" placeholder="Örn: HOSGELDIN20" required>
                    </div>
                    <div class="form-group">
                        <label for="coupon-description" class="form-label">Açıklama</label>
                        <textarea id="coupon-description" class="form-input" rows="2" placeholder="Kupon açıklaması (opsiyonel)"></textarea>
                    </div>
                    <div class="form-group-inline">
                        <div class="form-group" style="flex: 1;">
                            <label for="discount-type" class="form-label">İndirim Türü *</label>
                            <select id="discount-type" class="form-input" required>
                                <option value="fixed">Sabit Tutar (TL)</option>
                                <option value="percentage">Yüzde (%)</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label for="coupon-amount" class="form-label">İndirim Değeri *</label>
                            <input type="number" id="coupon-amount" class="form-input" step="0.01" min="0" placeholder="100" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="min-order-amount" class="form-label">Minimum Sipariş Tutarı (TL)</label>
                        <input type="number" id="min-order-amount" class="form-input" step="0.01" min="0" placeholder="0" value="0">
                    </div>
                    <div class="form-group" id="max-discount-group" style="display: none;">
                        <label for="max-discount-amount" class="form-label">Maksimum İndirim Tutarı (TL) - Yüzde indirimlerde</label>
                        <input type="number" id="max-discount-amount" class="form-input" step="0.01" min="0" placeholder="Opsiyonel">
                    </div>
                    <div class="form-group">
                        <label for="valid-days" class="form-label">Geçerlilik Süresi (Gün)</label>
                        <input type="number" id="valid-days" class="form-input" min="1" placeholder="30" value="30">
                    </div>

                    <hr class="divider">

                    <h4 class="form-label">Kuponu Hangi Satıcılara Uygula?</h4>

                    <div class="form-check">
                        <input type="checkbox" id="select-all-sellers">
                        <label for="select-all-sellers"><strong>Tüm Satıcıları Seç</strong></label>
                    </div>

                    <input type="text" id="seller-search" class="form-input" placeholder="Dükkan ara..." autocomplete="off"
                        style="margin:0.5rem 0 0.4rem;max-width:320px;">
                    <small id="seller-search-count" style="display:none;color:#888;font-size:0.82rem;margin-bottom:0.4rem;display:block;"></small>

                    <div id="seller-checkbox-list" class="seller-checkbox-list">
                    </div>

                    <button type="submit" class="btn btn-primary" style="margin-top: 1rem;">Kuponları Tanımla</button>
                </form>
            </div>
        </div>

        <div class="card" style="margin-top: 2rem;">
            <div class="card-content">
                <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.75rem;margin-bottom:0.75rem;">
                    <h3 class="checkout-card-title" style="margin:0;">Tanımlı Kuponlar</h3>
                    <div style="display:flex;align-items:center;gap:0.5rem;">
                        <input type="text" id="coupon-list-search" class="form-input" placeholder="Kupon kodu veya açıklama ara..." autocomplete="off"
                            style="width:260px;max-width:100%;">
                        <small id="coupon-list-count" style="white-space:nowrap;color:#888;font-size:0.82rem;display:none;"></small>
                    </div>
                </div>
                <div id="coupon-list-container"></div>
            </div>
        </div>

    </main>
</div>

<!-- Kupon düzenleme modal -->
<div id="coupon-edit-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content" style="max-width: 560px;">
        <div class="card">
            <div class="card-content">
                <h3 class="checkout-card-title">Kuponu Düzenle</h3>
                <form id="coupon-edit-form">
                    <input type="hidden" id="edit-coupon-id">
                    <div class="form-group">
                        <label for="edit-coupon-code" class="form-label">Kupon Kodu *</label>
                        <input type="text" id="edit-coupon-code" class="form-input" required>
                    </div>
                    <div class="form-group">
                        <label for="edit-coupon-description" class="form-label">Açıklama</label>
                        <textarea id="edit-coupon-description" class="form-input" rows="2"></textarea>
                    </div>
                    <div class="form-group-inline">
                        <div class="form-group" style="flex: 1;">
                            <label for="edit-coupon-discount-type" class="form-label">İndirim Türü</label>
                            <select id="edit-coupon-discount-type" class="form-input">
                                <option value="fixed">Sabit Tutar (TL)</option>
                                <option value="percentage">Yüzde (%)</option>
                            </select>
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label for="edit-coupon-amount" class="form-label">İndirim Değeri *</label>
                            <input type="number" id="edit-coupon-amount" class="form-input" step="0.01" min="0" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="edit-coupon-min-order" class="form-label">Min. Sipariş (TL)</label>
                        <input type="number" id="edit-coupon-min-order" class="form-input" step="0.01" min="0" value="0">
                    </div>
                    <div class="form-group">
                        <label for="edit-coupon-max-discount" class="form-label">Maks. İndirim (TL)</label>
                        <input type="number" id="edit-coupon-max-discount" class="form-input" step="0.01" min="0" placeholder="Opsiyonel">
                    </div>
                    <h4 class="form-label">Uygulanacak Satıcılar</h4>
                    <input type="text" id="edit-seller-search" class="form-input" placeholder="Dükkan ara..." autocomplete="off"
                        style="margin-bottom:0.4rem;max-width:100%;">
                    <div id="edit-coupon-seller-list" class="seller-checkbox-list" style="max-height: 200px; overflow-y: auto;">
                    </div>
                    <div style="display: flex; gap: 0.5rem; margin-top: 1rem;">
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                        <button type="button" class="btn btn-secondary" id="coupon-edit-cancel">İptal</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<style>
.modal-overlay { position: fixed; inset: 0; left: 0; right: 0; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; align-items: center; justify-content: center; padding: 1rem; }
.modal-overlay .modal-content { width: 100%; max-width: 560px; max-height: calc(100vh - 2rem); margin: 0 auto; position: relative; left: 0; right: 0; transform: none; overflow-y: auto; }
.modal-overlay .card { margin: 0; }
</style>
<script src="/assets/js/modules/ys-select.js"></script>
<script>
function initSellerSearch(inputId, listId, countId) {
    var input = document.getElementById(inputId);
    var list  = document.getElementById(listId);
    var countEl = countId ? document.getElementById(countId) : null;
    if (!input || !list) return;

    input.addEventListener('input', function() {
        var q = input.value.trim().toLowerCase();
        var items = list.querySelectorAll('.form-check');
        var visible = 0;
        items.forEach(function(item) {
            var label = item.querySelector('label');
            var name  = label ? label.textContent.toLowerCase() : '';
            var show  = !q || name.indexOf(q) !== -1;
            item.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        if (countEl) {
            if (q) {
                countEl.textContent = visible + ' dükkan bulundu';
                countEl.style.display = 'block';
            } else {
                countEl.style.display = 'none';
            }
        }
    });
}

document.addEventListener('DOMContentLoaded', function() {
    initYsSelects(document);
    initSellerSearch('seller-search', 'seller-checkbox-list', 'seller-search-count');

    // Kupon listesi arama
    var couponSearchInput = document.getElementById('coupon-list-search');
    var couponCountEl = document.getElementById('coupon-list-count');
    var couponContainer = document.getElementById('coupon-list-container');

    function applyCouponSearch() {
        if (!couponSearchInput || !couponContainer) return;
        var q = couponSearchInput.value.trim().toLowerCase();
        var items = couponContainer.querySelectorAll('.coupon-list-item');
        if (items.length === 0) return;
        var visible = 0;
        items.forEach(function(item) {
            var text = item.textContent.toLowerCase();
            var show = !q || text.indexOf(q) !== -1;
            item.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        if (couponCountEl) {
            if (q) {
                couponCountEl.textContent = visible + ' kupon bulundu';
                couponCountEl.style.display = 'inline';
            } else {
                couponCountEl.style.display = 'none';
            }
        }
    }

    if (couponSearchInput) {
        couponSearchInput.addEventListener('input', applyCouponSearch);
    }

    // Liste her yenilendiğinde (filtre değişince vb.) aramayı yeniden uygula
    if (couponContainer) {
        new MutationObserver(function() { applyCouponSearch(); })
            .observe(couponContainer, { childList: true, subtree: true });
    }

    // Edit modalı açıldığında yeniden init et + satıcı araması
    var editModal = document.getElementById('coupon-edit-modal');
    var editSearchInited = false;
    if (editModal) {
        var observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(m) {
                if (m.type === 'attributes' && m.attributeName === 'style') {
                    var sel = document.getElementById('edit-coupon-discount-type');
                    if (sel && !sel.classList.contains('ys-select-original')) {
                        initYsSelects(editModal);
                    }
                    if (!editSearchInited) {
                        initSellerSearch('edit-seller-search', 'edit-coupon-seller-list', null);
                        editSearchInited = true;
                    }
                    // Arama kutusunu temizle her açılışta
                    var es = document.getElementById('edit-seller-search');
                    if (es) { es.value = ''; es.dispatchEvent(new Event('input')); }
                }
            });
        });
        observer.observe(editModal, { attributes: true });
    }
});
</script>
