<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css?v=20260629-mobilefix1">
<link rel="stylesheet" href="/assets/css/pages/admin.css">
<link rel="stylesheet" href="/assets/css/pages/checkout.css">

<div class="panel-layout">

    <%- include('../partials/sidebar') %>

    <main class="panel-content">
        <h1 class="panel-title">Öneri & Şikayet Yönetimi <span id="feedback-open-badge" class="admin-fb-badge" style="display:none;"></span></h1>

        <div class="card">
            <div class="card-content">
                <!-- Sade filtre satırı: tür + rol + durum + arama -->
                <div style="display:flex;gap:0.6rem;flex-wrap:wrap;align-items:center;margin-bottom:0.85rem;">
                    <select id="admin-fb-type" class="form-input" style="width:auto;flex:0 0 auto;">
                        <option value="all">Tüm Türler</option>
                        <option value="suggestion">💡 Öneri</option>
                        <option value="complaint">⚠️ Şikayet</option>
                    </select>
                    <select id="admin-fb-role" class="form-input" style="width:auto;flex:0 0 auto;">
                        <option value="all">Tüm Roller</option>
                        <option value="buyer">👤 Alıcı</option>
                        <option value="seller">🏪 Satıcı</option>
                        <option value="courier">🛵 Kurye</option>
                    </select>
                    <select id="admin-fb-status" class="form-input" style="width:auto;flex:0 0 auto;">
                        <option value="all">Tüm Durumlar</option>
                        <option value="open">🆕 Açık</option>
                        <option value="in_review">🔎 İnceleniyor</option>
                        <option value="resolved">✅ Çözüldü</option>
                    </select>
                    <input type="text" id="admin-fb-search" class="form-input" style="flex:1;min-width:180px;" placeholder="Konu veya mesajda ara…">
                </div>

                <div id="admin-fb-list">
                    <p class="admin-fb-empty">Talepler yükleniyor…</p>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Detay / yanıt modalı -->
<div id="admin-fb-modal" class="modal-overlay" style="display:none;">
    <div class="modal-content" style="max-width:560px;">
        <div class="card">
            <div class="card-content">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">
                    <h3 class="checkout-card-title" id="admin-fb-modal-title" style="margin:0;">Talep Detayı</h3>
                    <button type="button" class="btn btn-sm btn-secondary" id="admin-fb-modal-close" aria-label="Kapat">✕</button>
                </div>
                <div id="admin-fb-modal-body"></div>
                <div class="form-group" style="margin-top:0.85rem;">
                    <label for="admin-fb-note" class="form-label">Yanıt / Not (kullanıcıya bildirim gider)</label>
                    <textarea id="admin-fb-note" class="form-input" rows="3" maxlength="3000" placeholder="Yanıtınızı yazın…"></textarea>
                </div>
                <div style="display:flex;flex-wrap:wrap;gap:0.5rem;justify-content:flex-end;margin-top:0.5rem;">
                    <button type="button" class="btn btn-sm btn-secondary" id="admin-fb-mark-review">🔎 İnceleniyor</button>
                    <button type="button" class="btn btn-sm btn-primary" id="admin-fb-mark-resolved">✅ Çözüldü + Yanıt Gönder</button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.modal-overlay { position: fixed; inset: 0; left: 0; right: 0; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; align-items: center; justify-content: center; padding: 1rem; }
.modal-overlay .modal-content { width: 100%; max-width: 560px; max-height: calc(100vh - 2rem); margin: 0 auto; position: relative; overflow-y: auto; }
.modal-overlay .card { margin: 0; }
.admin-fb-card { border:1px solid var(--border-color); border-radius:10px; padding:0.85rem 1rem; margin-bottom:0.75rem; background:var(--card-bg); color:var(--text-color); cursor:pointer; }
.admin-fb-card:hover { border-color: var(--primary-color); }
.admin-fb-card-head { display:flex; justify-content:space-between; align-items:center; gap:0.5rem; flex-wrap:wrap; }
.admin-fb-badge, .admin-fb-chip { display:inline-block; padding:0.15rem 0.6rem; border-radius:999px; font-size:0.78rem; font-weight:600; }
.admin-fb-meta { color:var(--text-color-light); font-size:0.87rem; margin-top:0.35rem; }
.admin-fb-empty { color:var(--text-color-light); }
</style>
