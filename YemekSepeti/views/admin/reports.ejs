<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css?v=20260629-mobilefix1">
<link rel="stylesheet" href="/assets/css/pages/admin.css">

<div class="panel-layout">
    <%- include('../partials/sidebar') %>
    <main class="panel-content">
        <h1 class="panel-title">Raporlar</h1>
        <div class="card reports-card" style="margin-bottom: 1.5rem;">
            <div class="card-content">
                <h3 class="checkout-card-title">📊 Rapor İndir</h3>
                <p style="font-size:0.85rem; color: var(--text-color-light); margin: 0 0 1rem;">Seçtiğiniz tarih aralığı için tüm platformun (satıcı + kurye + sipariş) detaylı raporunu indirin. Tarih boş bırakılırsa son 30 gün alınır.</p>
                <div style="display:flex; gap:1rem; align-items:flex-end; flex-wrap:wrap;">
                    <div>
                        <label for="export-start-date" style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Başlangıç</label>
                        <input type="date" id="export-start-date" style="padding:0.5rem; border:1px solid var(--border-color,#ddd); border-radius:8px;">
                    </div>
                    <div>
                        <label for="export-end-date" style="display:block; font-size:0.85rem; margin-bottom:0.3rem;">Bitiş</label>
                        <input type="date" id="export-end-date" style="padding:0.5rem; border:1px solid var(--border-color,#ddd); border-radius:8px;">
                    </div>
                    <button type="button" id="export-excel-btn" class="btn btn-primary">📥 Rapor İndir</button>
                    <span id="export-status" style="font-size:0.85rem; color: var(--text-color-light);"></span>
                </div>
            </div>
        </div>
        <div class="card reports-card">
            <div class="card-content">
                <h3 class="checkout-card-title">Özet İstatistikler</h3>
                <div id="reports-loading" class="reports-loading">Yükleniyor...</div>
                <div id="reports-error" class="reports-error" style="display: none;"></div>
                <div id="reports-summary" class="reports-stats-grid" style="display: none;">
                    <div class="reports-stat-card">
                        <span class="reports-stat-label">Toplam Sipariş</span>
                        <span id="stat-total-orders" class="reports-stat-value">0</span>
                    </div>
                    <div class="reports-stat-card">
                        <span class="reports-stat-label">Bugünkü Sipariş</span>
                        <span id="stat-orders-today" class="reports-stat-value">0</span>
                    </div>
                    <div class="reports-stat-card">
                        <span class="reports-stat-label">Bu Hafta</span>
                        <span id="stat-orders-week" class="reports-stat-value">0</span>
                    </div>
                    <div class="reports-stat-card">
                        <span class="reports-stat-label">Teslim Edilen</span>
                        <span id="stat-delivered" class="reports-stat-value">0</span>
                    </div>
                    <div class="reports-stat-card">
                        <span class="reports-stat-label">Toplam Gelir (TL)</span>
                        <span id="stat-revenue" class="reports-stat-value">0</span>
                    </div>
                    <div class="reports-stat-card">
                        <span class="reports-stat-label">Aktif Satıcı</span>
                        <span id="stat-sellers" class="reports-stat-value">0</span>
                    </div>
                    <div class="reports-stat-card">
                        <span class="reports-stat-label">Aktif Kurye</span>
                        <span id="stat-couriers" class="reports-stat-value">0</span>
                    </div>
                    <div class="reports-stat-card">
                        <span class="reports-stat-label">Toplam Kullanıcı</span>
                        <span id="stat-users" class="reports-stat-value">0</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="card reports-card" style="margin-top: 1.5rem;">
            <div class="card-content">
                <h3 class="checkout-card-title">Son 7 Gün – Sipariş & Ciro</h3>
                <div style="position: relative; height: 280px;">
                    <canvas id="reports-chart"></canvas>
                </div>
            </div>
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
(function() {
    const baseUrl = window.getBaseUrl ? window.getBaseUrl() : '';
    function authHeaders() {
        const t = localStorage.getItem('token');
        const h = { 'Content-Type': 'application/json' };
        if (t) h['Authorization'] = 'Bearer ' + t;
        return h;
    }
    async function load() {
        const loading = document.getElementById('reports-loading');
        const summary = document.getElementById('reports-summary');
        const errorEl = document.getElementById('reports-error');
        try {
            const res = await fetch(baseUrl + '/api/admin/reports/summary', { credentials: 'include', headers: authHeaders() });
            const data = await res.json();
            loading.style.display = 'none';
            if (data.success && data.summary) {
                errorEl.style.display = 'none';
                summary.style.display = 'grid';
                var s = data.summary;
                var set = function(id, val) { var el = document.getElementById(id); if (el) el.textContent = val; };
                set('stat-total-orders', s.totalOrders != null ? s.totalOrders : 0);
                set('stat-orders-today', s.ordersToday != null ? s.ordersToday : 0);
                set('stat-orders-week', s.ordersThisWeek != null ? s.ordersThisWeek : 0);
                set('stat-delivered', s.deliveredOrders != null ? s.deliveredOrders : 0);
                set('stat-revenue', s.totalRevenue != null ? Number(s.totalRevenue).toFixed(2) : '0');
                set('stat-sellers', s.activeSellers != null ? s.activeSellers : 0);
                set('stat-couriers', s.activeCouriers != null ? s.activeCouriers : 0);
                set('stat-users', s.totalUsers != null ? s.totalUsers : 0);
            } else {
                errorEl.style.display = 'block';
                errorEl.textContent = data.message || 'Rapor yüklenemedi.';
            }
        } catch (e) {
            loading.style.display = 'none';
            summary.style.display = 'none';
            errorEl.style.display = 'block';
            errorEl.textContent = 'Rapor yüklenirken bağlantı hatası oluştu.';
        }
    }
    async function loadChart() {
        const canvas = document.getElementById('reports-chart');
        if (!canvas || typeof Chart === 'undefined') return;
        try {
            const res = await fetch(baseUrl + '/api/admin/reports/chart', { credentials: 'include', headers: authHeaders() });
            const data = await res.json();
            if (!data.success || !data.chart || !data.chart.length) return;
            const labels = data.chart.map(function(d) { return d.label; });
            const ordersData = data.chart.map(function(d) { return d.orders; });
            const revenueData = data.chart.map(function(d) { return d.revenue; });
            new Chart(canvas, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        { label: 'Sipariş sayısı', data: ordersData, backgroundColor: 'rgba(231, 76, 60, 0.7)', yAxisID: 'y' },
                        { label: 'Ciro (TL)', data: revenueData, backgroundColor: 'rgba(46, 204, 113, 0.7)', yAxisID: 'y1' }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { type: 'linear', position: 'left', beginAtZero: true },
                        y1: { type: 'linear', position: 'right', beginAtZero: true, grid: { drawOnChartArea: false } }
                    }
                }
            });
        } catch (e) {}
    }
    function loadAll() {
        load();
        loadChart();
    }
    function filenameFromCD(cd, fallback) {
        cd = cd || '';
        let m = cd.match(/filename\*=UTF-8''([^;]+)/i);
        if (m) { try { return decodeURIComponent(m[1]); } catch (e) {} }
        m = cd.match(/filename="?([^";]+)"?/i);
        return (m && m[1]) || fallback;
    }
    function initExport() {
        const btn = document.getElementById('export-excel-btn');
        const statusEl = document.getElementById('export-status');
        if (!btn) return;
        btn.addEventListener('click', async () => {
            const sd = document.getElementById('export-start-date').value;
            const ed = document.getElementById('export-end-date').value;
            const params = new URLSearchParams();
            if (sd) params.append('startDate', sd);
            if (ed) params.append('endDate', ed);
            statusEl.textContent = 'Hazırlanıyor...';
            btn.disabled = true;
            try {
                const res = await fetch(baseUrl + '/api/admin/reports/export?' + params.toString(), { credentials: 'include' });
                if (!res.ok) {
                    const data = await res.json().catch(() => ({}));
                    throw new Error(data.message || 'Rapor indirilemedi.');
                }
                const filename = filenameFromCD(res.headers.get('Content-Disposition'), 'Ev-Lezzetleri-Genel-Rapor.xlsx');
                const blob = await res.blob();
                const a = document.createElement('a');
                const objUrl = URL.createObjectURL(blob);
                a.href = objUrl;
                a.download = filename;
                document.body.appendChild(a);
                a.click();
                a.remove();
                URL.revokeObjectURL(objUrl);
                statusEl.textContent = '';
            } catch (err) {
                statusEl.textContent = err.message || 'Rapor indirilirken hata oluştu.';
            } finally {
                btn.disabled = false;
            }
        });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', () => { loadAll(); initExport(); });
    else { loadAll(); initExport(); }
})();
</script>

