<!-- Custom Confirm Modal -->
<div class="custom-confirm-overlay" id="custom-confirm-overlay">
    <div class="custom-confirm-modal">
        <h3 id="custom-confirm-title">Onay Gerekli</h3>
        <p id="custom-confirm-message">Bu işlemi gerçekleştirmek istediğinize emin misiniz?</p>
        <div class="custom-confirm-buttons">
            <button type="button" class="custom-confirm-btn cancel" id="custom-confirm-cancel">İPTAL</button>
            <button type="button" class="custom-confirm-btn confirm" id="custom-confirm-ok">TAMAM</button>
        </div>
    </div>
</div>

<script>
var baseUrl = (typeof window.getBaseUrl === 'function' ? window.getBaseUrl() : '') || '';
var allMeals = [];
var allCitiesRaw = [];

// Custom Confirm Helper Function
function showCustomConfirm(title, message) {
    return new Promise((resolve) => {
        const overlay = document.getElementById('custom-confirm-overlay');
        document.getElementById('custom-confirm-title').textContent = title;
        document.getElementById('custom-confirm-message').textContent = message;
        
        overlay.style.display = 'flex';
        
        const btnCancel = document.getElementById('custom-confirm-cancel');
        const btnConfirm = document.getElementById('custom-confirm-ok');
        
        // Remove old event listeners by replacing nodes
        const newBtnCancel = btnCancel.cloneNode(true);
        const newBtnConfirm = btnConfirm.cloneNode(true);
        btnCancel.parentNode.replaceChild(newBtnCancel, btnCancel);
        btnConfirm.parentNode.replaceChild(newBtnConfirm, btnConfirm);
        
        const handleClose = (result) => {
            overlay.style.display = 'none';
            resolve(result);
        };

        newBtnCancel.addEventListener('click', () => handleClose(false));
        newBtnConfirm.addEventListener('click', () => handleClose(true));
    });
}

async function loadMenuItems() {
    const sellerId = document.getElementById('filter-seller').value;
    const isAvailable = document.getElementById('filter-availability').value;
    const isApproved = document.getElementById('filter-approval').value;
    const search = document.getElementById('filter-search').value.trim();
    const province = document.getElementById('filter-province').value;
    const district = document.getElementById('filter-district').value;

    const grid = document.getElementById('menu-grid');
    grid.innerHTML = '<div class="empty-state-menu"><div class="icon">⏳</div><h3>Yükleniyor...</h3></div>';

    let params = new URLSearchParams();
    if (sellerId) params.append('sellerId', sellerId);
    if (isAvailable) params.append('isAvailable', isAvailable);
    if (isApproved) params.append('isApproved', isApproved);
    if (search) params.append('search', search);
    if (province) params.append('province', province);
    if (district) params.append('district', district);

    try {
        const res = await fetch(`${baseUrl}/api/admin/menu-items?${params.toString()}`, { credentials: 'include' });
        const result = await res.json();

        if (!result.success) {
            grid.innerHTML = '<div class="empty-state-menu"><div class="icon">⚠️</div><h3>Hata oluştu</h3><p>' + (result.message || '') + '</p></div>';
            return;
        }

        allMeals = result.data || [];

        // İstatistikler
        const total = allMeals.length;
        const active = allMeals.filter(m => m.is_available).length;
        const inactive = total - active;
        const pending = allMeals.filter(m => m.is_approved === false).length;
        const uniqueSellers = new Set(allMeals.map(m => m.seller?.id)).size;

        // Satıcı dropdown'ını doldur (ilk yüklemede)
        const sellerSelect = document.getElementById('filter-seller');
        if (sellerSelect.options.length <= 1 && result.sellers) {
            window.allSellers = result.sellers;
            result.sellers.forEach(s => {
                const opt = document.createElement('option');
                opt.value = s.id;
                opt.textContent = s.shop_name;
                sellerSelect.appendChild(opt);
            });
            if(sellerSelect.syncCustomUI) sellerSelect.syncCustomUI();
        }

        // Seçilen satıcıya göre İL listesini dinamik daralt
        const provinceSelect = document.getElementById('filter-province');
        let currentProvince = provinceSelect.value;
        let validCities = [...allCitiesRaw]; // varsayılan olarak hepsi

        if (sellerId && window.allSellers) {
            const seller = window.allSellers.find(s => s.id == sellerId);
            if (seller && seller.location) {
                // Satıcının lokasyon stringi içinde geçen illeri bul
                const matchedCities = allCitiesRaw.filter(city => seller.location.includes(city));
                if (matchedCities.length > 0) {
                    validCities = matchedCities;
                }
            }
        }

        // İl dropdown'ını yeniden oluştur
        // Eğer seçili il yeni valid listesinde yoksa seçimi sıfırla
        let clearProvince = currentProvince && !validCities.includes(currentProvince);
        provinceSelect.innerHTML = '<option value="">Tüm İller</option>';
        validCities.forEach(city => {
            const opt = document.createElement('option');
            opt.value = city;
            opt.textContent = city;
            if (city === currentProvince && !clearProvince) opt.selected = true;
            provinceSelect.appendChild(opt);
        });
        
        if (clearProvince || provinceSelect.value === "") {
            provinceSelect.value = "";
            document.getElementById('filter-district').innerHTML = '<option value="">Önce İl Seçiniz</option>';
            document.getElementById('filter-district').disabled = true;
            if(document.getElementById('filter-district').syncCustomUI) document.getElementById('filter-district').syncCustomUI();
        }

        if(provinceSelect.syncCustomUI) provinceSelect.syncCustomUI();

        document.getElementById('stat-total').textContent = total;
        document.getElementById('stat-active').textContent = active;
        document.getElementById('stat-inactive').textContent = inactive;
        document.getElementById('stat-pending').textContent = pending;
        document.getElementById('stat-sellers').textContent = uniqueSellers;

        if (allMeals.length === 0) {
            grid.innerHTML = '<div class="empty-state-menu"><div class="icon">🍽️</div><h3>Ürün bulunamadı</h3><p>Filtre kriterlerinize uygun ürün bulunmuyor.</p></div>';
            return;
        }

        let html = '';
        allMeals.forEach(m => {
            const imgHtml = m.image_url
                ? `<div class="menu-card-img"><img src="${m.image_url}" alt="${m.name}" onerror="this.parentElement.innerHTML='🍽️'"></div>`
                : `<div class="menu-card-img">🍽️</div>`;

            const availBadge = m.is_available
                ? '<span class="avail-badge active">✅ Aktif</span>'
                : '<span class="avail-badge inactive">❌ Pasif</span>';
                
            const approvalBadge = m.is_approved === false
                ? '<span class="avail-badge inactive" style="background: rgba(243,156,18,0.15); color: #f39c12;">⏳ Onay Bekliyor</span>'
                : '';

            const stockText = m.stock_quantity === -1 ? '∞' : m.stock_quantity;

            html += `
                <div class="menu-card" data-meal-id="${m.id}" style="${m.is_approved === false ? 'border: 2px solid #f39c12;' : ''}">
                    ${imgHtml}
                    <div class="menu-card-body">
                        <span class="shop-name">🏪 ${m.seller?.shop_name || 'Bilinmeyen'}</span>
                        <h4>${m.name}</h4>
                        <span class="category-tag">${m.category}</span>
                        ${m.description ? `<p class="desc">${m.description}</p>` : ''}
                        <div class="price-row">
                            <span class="price">${m.price.toLocaleString('tr-TR', { minimumFractionDigits: 2 })} TL</span>
                            <span style="font-size: 0.8rem; color: #888;">Stok: ${stockText}</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            ${availBadge}
                            ${approvalBadge}
                        </div>
                    </div>
                    <div class="menu-card-actions">
                        ${m.is_approved === false ? `
                            <button class="btn btn-success btn-sm btn-approve-meal" data-id="${m.id}" style="background-color: #27ae60; color: white;">✅ Onayla</button>
                        ` : ''}
                        <button class="btn btn-secondary btn-sm btn-toggle-meal" data-id="${m.id}" title="${m.is_available ? 'Pasif Yap' : 'Aktif Yap'}">
                            ${m.is_available ? '🚫 Pasif' : '✅ Aktif'}
                        </button>
                        <button class="btn btn-primary btn-sm btn-edit-meal" data-id="${m.id}">✏️</button>
                        <button class="btn btn-sm btn-delete-meal" data-id="${m.id}" style="background: rgba(239,68,68,0.1); color: #E74C3C; border: 1px solid rgba(239,68,68,0.3);">🗑️</button>
                    </div>
                </div>
            `;
        });
        grid.innerHTML = html;

    } catch (e) {
        grid.innerHTML = '<div class="empty-state-menu"><div class="icon">⚠️</div><h3>Sunucu hatası</h3><p>' + e.message + '</p></div>';
    }
}

function openEditModal(mealId) {
    const meal = allMeals.find(m => m.id === mealId);
    if (!meal) return;

    document.getElementById('edit-meal-id').value = meal.id;
    document.getElementById('edit-name').value = meal.name || '';
    document.getElementById('edit-category').value = meal.category || '';
    document.getElementById('edit-description').value = meal.description || '';
    document.getElementById('edit-price').value = meal.price || 0;
    document.getElementById('edit-stock').value = meal.stock_quantity != null ? meal.stock_quantity : -1;
    document.getElementById('edit-image-url').value = meal.image_url || '';
    document.getElementById('edit-availability').value = meal.is_available ? 'true' : 'false';
    document.getElementById('edit-modal-title').textContent = `"${meal.name}" Düzenle`;
    document.getElementById('edit-modal-overlay').style.display = 'flex';
}

async function saveEditedMeal() {
    const mealId = document.getElementById('edit-meal-id').value;
    if (!mealId) return;

    const body = {
        name: document.getElementById('edit-name').value.trim(),
        category: document.getElementById('edit-category').value.trim(),
        description: document.getElementById('edit-description').value.trim(),
        price: parseFloat(document.getElementById('edit-price').value),
        stock_quantity: parseInt(document.getElementById('edit-stock').value),
        image_url: document.getElementById('edit-image-url').value.trim(),
        is_available: document.getElementById('edit-availability').value === 'true'
    };

    if (!body.name || !body.category || isNaN(body.price) || body.price <= 0) {
        alert('Ürün adı, kategori ve geçerli bir fiyat zorunludur.');
        return;
    }

    try {
        const res = await fetch(`${baseUrl}/api/admin/menu-items/${mealId}`, {
            method: 'PUT',
            credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        const result = await res.json();
        if (result.success) {
            document.getElementById('edit-modal-overlay').style.display = 'none';
            loadMenuItems();
        } else {
            alert(result.message || 'Güncelleme başarısız.');
        }
    } catch (e) {
        alert('Sunucu hatası: ' + e.message);
    }
}

async function toggleMeal(mealId) {
    try {
        const res = await fetch(`${baseUrl}/api/admin/menu-items/${mealId}/toggle`, {
            method: 'PATCH',
            credentials: 'include'
        });
        const result = await res.json();
        if (result.success) {
            loadMenuItems();
        } else {
            alert(result.message || 'İşlem başarısız.');
        }
    } catch (e) {
        alert('Sunucu hatası: ' + e.message);
    }
}

async function approveMeal(mealId) {
    try {
        const res = await fetch(`${baseUrl}/api/admin/menu-items/${mealId}/approve`, {
            method: 'PATCH',
            credentials: 'include'
        });
        const result = await res.json();
        if (result.success) {
            loadMenuItems();
        } else {
            alert(result.message || 'İşlem başarısız.');
        }
    } catch (e) {
        alert('Sunucu hatası: ' + e.message);
    }
}

async function deleteMeal(mealId) {
    const meal = allMeals.find(m => m.id === mealId);
    const mealName = meal ? meal.name : mealId;
    
    const isConfirmed = await showCustomConfirm("Onay Gerekli", `"${mealName}" ürününü silmek istediğinize emin misiniz? Bu işlem geri alınamaz.`);
    if (!isConfirmed) return;

    try {
        const res = await fetch(`${baseUrl}/api/admin/menu-items/${mealId}`, {
            method: 'DELETE',
            credentials: 'include'
        });
        const result = await res.json();
        if (result.success) {
            loadMenuItems();    
        } else {
            alert(result.message || 'Silme başarısız.');
        }
    } catch (e) {
        alert('Sunucu hatası: ' + e.message);
    }
}

document.addEventListener('DOMContentLoaded', () => {
    loadMenuItems();

    document.getElementById('menu-filter-form').addEventListener('submit', (e) => {
        e.preventDefault();
    });

    // Otomatik filtreleme (Dropdown'lardan seçim yapınca anında)
    document.getElementById('menu-filter-form').addEventListener('change', (e) => {
        if (e.target.id === 'filter-seller') {
            // Eğer satıcı değiştiriliyorsa önceki il/ilçe seçimlerini DOM üzerinden sıfırla ki çakışmasın
            document.getElementById('filter-province').value = '';
            document.getElementById('filter-district').value = '';
            // district'i varsayılan haline getir
            document.getElementById('filter-district').innerHTML = '<option value="">Önce İl Seçiniz</option>';
            document.getElementById('filter-district').disabled = true;
            if(document.getElementById('filter-district').syncCustomUI) document.getElementById('filter-district').syncCustomUI();
        }
        loadMenuItems();
    });

    // Arama kutusuna yazarken otomatik filtreleme (Debounce - bekleme süreli)
    let searchTimeout;
    document.getElementById('filter-search').addEventListener('input', () => {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => loadMenuItems(), 300);
    });

    // Delegated events for menu grid
    document.getElementById('menu-grid').addEventListener('click', (e) => {
        const editBtn = e.target.closest('.btn-edit-meal');
        const toggleBtn = e.target.closest('.btn-toggle-meal');
        const deleteBtn = e.target.closest('.btn-delete-meal');
        const approveBtn = e.target.closest('.btn-approve-meal');

        if (editBtn) {
            openEditModal(parseInt(editBtn.dataset.id));
        } else if (toggleBtn) {
            toggleMeal(parseInt(toggleBtn.dataset.id));
        } else if (deleteBtn) {
            deleteMeal(parseInt(deleteBtn.dataset.id));
        } else if (approveBtn) {
            approveMeal(parseInt(approveBtn.dataset.id));
        }
    });

    // Edit modal events
    document.getElementById('edit-modal-close').addEventListener('click', () => {
        document.getElementById('edit-modal-overlay').style.display = 'none';
    });
    document.getElementById('edit-cancel-btn').addEventListener('click', () => {
        document.getElementById('edit-modal-overlay').style.display = 'none';
    });
    document.getElementById('edit-modal-overlay').addEventListener('click', (e) => {
        if (e.target === document.getElementById('edit-modal-overlay')) {
            document.getElementById('edit-modal-overlay').style.display = 'none';
        }
    });
    document.getElementById('edit-save-btn').addEventListener('click', saveEditedMeal);

    // === GÜZEL DROPDOWN JS'İ ===
    function createCustomSelects() {
        document.querySelectorAll('select').forEach(select => {
            if (select.closest('.edit-modal') || select.classList.contains('ys-select-original')) return; // Modaldaki selectleri elleme
            
            select.classList.add('ys-select-original');
            
            const wrapper = document.createElement('div');
            wrapper.className = 'ys-select-wrapper';
            select.parentNode.insertBefore(wrapper, select);
            wrapper.appendChild(select);
            
            const trigger = document.createElement('div');
            trigger.className = 'ys-select-trigger' + (select.disabled ? ' disabled' : '');
            trigger.innerHTML = `<span class="ys-select-text">${select.options[select.selectedIndex]?.text || ''}</span><span class="ys-select-arrow">▼</span>`;
            
            const panel = document.createElement('div');
            panel.className = 'ys-select-panel';
            panel.innerHTML = `
                <div class="ys-select-search">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <input type="text" placeholder="Ara...">
                </div>
                <ul class="ys-select-list"></ul>
                <div class="ys-select-empty">Sonuç bulunamadı</div>
            `;
            
            wrapper.appendChild(trigger);
            wrapper.appendChild(panel);
            
            const list = panel.querySelector('.ys-select-list');
            const searchInput = panel.querySelector('input');
            const emptyMsg = panel.querySelector('.ys-select-empty');
            const textSpan = trigger.querySelector('.ys-select-text');
            
            const renderOptions = () => {
                list.innerHTML = '';
                Array.from(select.options).forEach((opt, idx) => {
                    const li = document.createElement('li');
                    li.textContent = opt.text;
                    li.dataset.value = opt.value;
                    if (opt.selected) li.classList.add('selected');
                    
                    li.addEventListener('click', (e) => {
                        e.stopPropagation();
                        select.value = opt.value;
                        textSpan.textContent = opt.text;
                        select.dispatchEvent(new Event('change', { bubbles: true }));
                        closePanel();
                        // Tüm li'lerden selected kaldır
                        Array.from(list.children).forEach(c => c.classList.remove('selected'));
                        li.classList.add('selected');
                    });
                    list.appendChild(li);
                });
            };
            renderOptions();
            
            const openPanel = () => {
                if (select.disabled || trigger.classList.contains('disabled')) return;
                document.querySelectorAll('.ys-select-panel.open').forEach(p => closePanel(p.parentNode));
                trigger.classList.add('open');
                panel.classList.add('open');
                searchInput.value = '';
                filterList('');
                setTimeout(() => searchInput.focus(), 50);
            };
            
            const closePanel = (wrap = wrapper) => {
                const trg = wrap.querySelector('.ys-select-trigger');
                const pnl = wrap.querySelector('.ys-select-panel');
                if (trg) trg.classList.remove('open');
                if (pnl) pnl.classList.remove('open');
            };
            
            trigger.addEventListener('click', (e) => {
                e.stopPropagation();
                if (panel.classList.contains('open')) closePanel();
                else openPanel();
            });
            
            searchInput.addEventListener('input', (e) => {
                filterList(e.target.value.trim().toLowerCase());
            });
            
            function filterList(query) {
                let hasVisible = false;
                Array.from(list.children).forEach(li => {
                    if (li.textContent.toLowerCase().includes(query)) {
                        li.classList.remove('hidden');
                        hasVisible = true;
                    } else {
                        li.classList.add('hidden');
                    }
                });
                emptyMsg.style.display = hasVisible ? 'none' : 'block';
            }
            
            // Dışarı tıklandığında kapat
            document.addEventListener('click', (e) => {
                if (!wrapper.contains(e.target)) {
                    closePanel();
                }
            });

            // Select elemanı dışarıdan değiştiğinde tetiklenecek observer mantığı
            select.syncCustomUI = () => {
                renderOptions();
                textSpan.textContent = select.options[select.selectedIndex]?.text || '';
                if(select.disabled) trigger.classList.add('disabled');
                else trigger.classList.remove('disabled');
            };
        });
    }

    // Adres/Lokasyon yönetimi
    const provinceSelect = document.getElementById('filter-province');
    const districtSelect = document.getElementById('filter-district');

    // İlleri Yükle
    fetch(`${baseUrl}/api/address/cities`)
        .then(res => res.json())
        .then(data => {
            if(data.success && data.cities) {
                allCitiesRaw = data.cities;
                data.cities.forEach(city => {
                    const option = document.createElement('option');
                    option.value = city;
                    option.textContent = city;
                    provinceSelect.appendChild(option);
                });
                if(provinceSelect.syncCustomUI) provinceSelect.syncCustomUI();
            }
        }).catch(err => console.error("İller yüklenemedi:", err));

    // İl değiştiğinde ilçeleri yükle
    provinceSelect.addEventListener('change', (e) => {
        const city = e.target.value;
        districtSelect.innerHTML = '<option value="">Tüm İlçeler</option>';
        
        if (!city) {
            districtSelect.disabled = true;
            districtSelect.innerHTML = '<option value="">Önce İl Seçiniz</option>';
            if(districtSelect.syncCustomUI) districtSelect.syncCustomUI();
            return;
        }

        districtSelect.disabled = true;
        districtSelect.innerHTML = '<option value="">Yükleniyor...</option>';
        if(districtSelect.syncCustomUI) districtSelect.syncCustomUI();

        fetch(`${baseUrl}/api/address/districts/${encodeURIComponent(city)}`)
            .then(res => res.json())
            .then(data => {
                districtSelect.innerHTML = '<option value="">Tüm İlçeler</option>';
                if(data.success && data.districts) {
                    data.districts.forEach(district => {
                        const option = document.createElement('option');
                        option.value = district;
                        option.textContent = district;
                        districtSelect.appendChild(option);
                    });
                    districtSelect.disabled = false;
                    if(districtSelect.syncCustomUI) districtSelect.syncCustomUI();
                }
            }).catch(err => {
                console.error("İlçeler yüklenemedi:", err);
                districtSelect.innerHTML = '<option value="">Hata Oluştu</option>';
                districtSelect.disabled = true;
                if(districtSelect.syncCustomUI) districtSelect.syncCustomUI();
            });
    });

    // Custom UI'ları başlat
    createCustomSelects();

});
</script>
