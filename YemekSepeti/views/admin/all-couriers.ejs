<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css">
<link rel="stylesheet" href="/assets/css/pages/admin.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
.actions-bar {
    display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem;
    background: var(--card-bg, #fff); padding: 1.5rem; border-radius: 12px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
}
.actions-bar .form-group { margin: 0; min-width: 200px; flex: 1; }
.actions-bar label { display: block; font-weight: 600; margin-bottom: 0.5rem; }
.actions-bar input, .actions-bar select {
    width: 100%; padding: 0.75rem; border: 1px solid var(--border-color, #eee); border-radius: 8px;
}
.actions-bar button { height: auto; align-self: flex-end; padding: 0.75rem 1.5rem; }

.status-badge { padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; }
.status-online { background-color: rgba(16, 185, 129, 0.15); color: #10B981; }
.status-offline { background-color: rgba(239, 68, 68, 0.15); color: #E74C3C; }
.status-pending { background-color: rgba(245, 158, 11, 0.15); color: #F59E0B; }

.actions-bar input, .actions-bar select {
    background: #fff; color: #111;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
}
.actions-bar input::placeholder { color: #999; }

:root[data-theme="dark"] .actions-bar input,
:root[data-theme="dark"] .actions-bar select {
    background: rgba(30, 41, 59, 0.85);
    color: #F8FAFC;
    border-color: rgba(148, 163, 184, 0.28);
}
:root[data-theme="dark"] .actions-bar input::placeholder { color: #94A3B8; }
:root[data-theme="dark"] .actions-bar select option { background: #1E293B; color: #F8FAFC; }

/* === MODERN ARAMALI SELECT === */
.ys-select-wrapper { position: relative; width: 100%; text-align: left; }
.ys-select-original { display: none !important; }
.ys-select-trigger {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; padding: 0.65rem 1rem; background: var(--card-bg, #fff);
    border: 1px solid var(--border-color, #e2e8f0); border-radius: 8px;
    color: var(--text-color, #334155); font-size: 0.9rem; cursor: pointer; transition: all 0.2s;
    user-select: none;
}
.ys-select-trigger:hover { border-color: rgba(220, 38, 38, 0.4); }
.ys-select-trigger.open { border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1); }
.ys-select-arrow { opacity: 0.5; transition: transform 0.2s; font-size: 0.7rem; }
.ys-select-trigger.open .ys-select-arrow { transform: rotate(180deg); }
.ys-select-panel {
    position: absolute; top: calc(100% + 5px); left: 0; right: 0; background: var(--card-bg, #fff);
    border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.2); z-index: 200; opacity: 0; visibility: hidden;
    transform: translateY(-5px); transition: all 0.2s; display: flex; flex-direction: column;
}
.ys-select-panel.open { opacity: 1; visibility: visible; transform: translateY(0); }
.ys-select-search { padding: 0.5rem; border-bottom: 1px solid var(--border-color, #f1f5f9); position: relative; }
.ys-select-search input {
    width: 100%; padding: 0.5rem 0.5rem 0.5rem 2.2rem; border: 1px solid var(--border-color, #e2e8f0); border-radius: 6px;
    font-size: 0.85rem; outline: none; background: transparent; color: var(--text-color); box-sizing: border-box; transition: border-color 0.2s;
}
.ys-select-search input:focus { border-color: #ef4444; }
.ys-select-search svg { position: absolute; left: 1.1rem; top: 50%; transform: translateY(-50%); color: var(--text-color, #94a3b8); width: 14px; height: 14px; pointer-events: none; opacity: 0.5; }
.ys-select-list { list-style: none; padding: 0; margin: 0; max-height: 220px; overflow-y: auto; scrollbar-width: thin; scrollbar-color: rgba(239, 68, 68, 0.3) transparent; }
.ys-select-list::-webkit-scrollbar { width: 6px; }
.ys-select-list::-webkit-scrollbar-thumb { background: rgba(239, 68, 68, 0.3); border-radius: 4px; }
.ys-select-list li { padding: 0.6rem 1rem; cursor: pointer; font-size: 0.85rem; color: var(--text-color, #334155); transition: background 0.15s; }
.ys-select-list li:hover { background: rgba(239, 68, 68, 0.05); color: #ef4444; }
.ys-select-list li.selected { background: rgba(239, 68, 68, 0.1); color: #ef4444; font-weight: 600; border-left: 3px solid #ef4444; padding-left: calc(1rem - 3px); }
.ys-select-list li.hidden { display: none; }
.ys-select-empty { padding: 1rem; text-align: center; color: #888; font-size: 0.85rem; display: none; }

/* Modal CSS */
.stats-modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 9999; display: none; align-items: center; justify-content: center; padding: 1.5rem; }
.stats-modal { background: var(--card-bg, #fff); border-radius: 16px; width: 100%; max-width: 800px; max-height: 90vh; display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.3); }
.stats-modal-header { padding: 1.5rem; border-bottom: 1px solid var(--border-color, #eee); display: flex; justify-content: space-between; align-items: center; }
.stats-modal-header h3 { margin: 0; font-size: 1.4rem; }
.stats-modal-body { padding: 1.5rem; overflow-y: auto; display: flex; flex-direction: column; gap: 1.5rem; }
.stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
.stat-box { background: rgba(0,0,0,0.02); border: 1px solid var(--border-color, #eee); padding: 1rem; border-radius: 12px; text-align: center; }
.stat-box h4 { margin: 0 0 0.5rem 0; font-size: 0.9rem; color: #666; }
.stat-box .value { font-size: 1.5rem; font-weight: bold; color: var(--primary-color); }
.map-container { height: 300px; width: 100%; border-radius: 12px; overflow: hidden; border: 1px solid var(--border-color, #eee); }
</style>

<div class="panel-layout">
    <%- include('../partials/sidebar') %>
    <main class="panel-content">
        <h1 class="panel-title">Tüm Kuryeler</h1>
        <p class="panel-subtitle">Sistemdeki aktif ve pasif tüm kuryeleri görüntüleyip istatistiklerini inceleyebilirsiniz.</p>

        <form id="filter-form" class="actions-bar">
            <div class="form-group">
                <label>Durum</label>
                <select id="filter-status">
                    <option value="all">Tümü</option>
                    <option value="online">Sadece Çevrimiçi (Aktif Görev Alabilir)</option>
                    <option value="offline">Sadece Çevrimdışı (Pasif)</option>
                </select>
            </div>
            <div class="form-group">
                <label>Araç Tipi</label>
                <select id="filter-vehicle">
                    <option value="all">Tümü</option>
                    <option value="motorcycle">Motosiklet</option>
                    <option value="car">Otomobil</option>
                    <option value="bicycle">Bisiklet</option>
                </select>
            </div>
            <div class="form-group">
                <label>Kurye Ara (İsim, Telefon, E-posta)</label>
                <input type="text" id="filter-search" placeholder="örn. Ahmet Yılmaz">
            </div>
            <button type="submit" class="btn btn-primary">Filtrele</button>
        </form>

        <div class="card">
            <div class="card-content">
                <div class="table-responsive">
                    <table class="panel-table">
                        <thead>
                            <tr>
                                <th>Kurye Bilgisi</th>
                                <th>İletişim</th>
                                <th>Kullandığı Araç</th>
                                <th>Onay ve Aktiflik</th>
                                <th class="text-end">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody id="couriers-tbody">
                            <tr><td colspan="5" class="text-center py-4">Veriler yükleniyor...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Modal -->
<div id="stats-modal-overlay" class="stats-modal-overlay">
    <div class="stats-modal">
        <div class="stats-modal-header">
            <h3 id="modal-courier-name">Kurye Detayları</h3>
            <button type="button" id="modal-close" class="btn btn-secondary btn-sm">Kapat</button>
        </div>
        <div class="stats-modal-body">
            <div class="stats-grid">
                <div class="stat-box">
                    <h4>✅ Tamamlanan Siparişler</h4>
                    <div class="value" id="modal-stat-delivered">0</div>
                </div>
                <div class="stat-box">
                    <h4>❌ İptal Edilenler</h4>
                    <div class="value" id="modal-stat-cancelled">0</div>
                </div>
                <div class="stat-box">
                    <h4>💰 Toplam Tahmini Kazanç</h4>
                    <div class="value" id="modal-stat-earnings">0.00 TL</div>
                </div>
            </div>
            <div>
                <h4 style="margin-bottom: 0.5rem;">📍 Son Bilinen Konum</h4>
                <div id="courier-map" class="map-container"></div>
                <p id="map-fallback-text" style="color: #666; font-size: 0.9rem; text-align: center; margin-top: 2rem; display: none;">Kurye henüz herhangi bir konum bildirisi yapmamış.</p>
            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
var baseUrl = (typeof window.getBaseUrl === 'function' ? window.getBaseUrl() : '') || '';
var mapInstance = null;
var mapMarker = null;

async function loadCouriers() {
    const status = document.getElementById('filter-status').value;
    const vehicle = document.getElementById('filter-vehicle').value;
    const search = document.getElementById('filter-search').value.trim();
    
    const tbody = document.getElementById('couriers-tbody');
    tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4">Yükleniyor...</td></tr>';
    
    let queryParams = new URLSearchParams();
    if(status && status !== 'all') queryParams.append('status', status);
    if(vehicle && vehicle !== 'all') queryParams.append('vehicleType', vehicle);
    if(search) queryParams.append('search', search);

    try {
        const res = await fetch(`${baseUrl}/api/admin/all-couriers?${queryParams.toString()}`, { credentials: 'include' });
        const result = await res.json();
        
        if(!result.success || !result.data || result.data.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted">Arama kriterlerine uygun kurye bulunamadı.</td></tr>';
            return;
        }

        const vehicleTitles = {
            'motorcycle': 'Motosiklet',
            'car': 'Otomobil',
            'bicycle': 'Bisiklet'
        };

        let html = '';
        result.data.forEach(c => {
            const isApproved = c.is_active && c.courier && c.courier.is_active;
            const statusHtml = c.courier_status === 'online' 
                ? '<span class="status-badge status-online">🟢 Online</span>' 
                : '<span class="status-badge status-offline">🔴 Offline</span>';

            const approvalHtml = isApproved 
                ? '<span style="color:#10B981; font-size:0.85rem; font-weight:bold;">✔ Onaylanmış</span>' 
                : '<span style="color:#E74C3C; font-size:0.85rem; font-weight:bold;">⏳ Onay Bekliyor</span>';

            const plate = c.courier && c.courier.plate_number ? c.courier.plate_number : 'Plaka Girilmemiş';
            const vehicleText = vehicleTitles[c.vehicle_type] || c.vehicle_type || 'Belirtilmemiş';

            html += `
                <tr class="align-middle">
                    <td>
                        <div style="font-weight: 600; color: var(--text-color); font-size: 1.05rem;">${c.fullname}</div>
                        <div style="font-size: 0.85rem; color: #888;">Katılım: ${new Date(c.created_at).toLocaleDateString('tr-TR')}</div>
                    </td>
                    <td>
                        <div>${c.phone || 'Telefon yok'}</div>
                        <div style="color: #666; font-size: 0.85rem;">${c.email}</div>
                    </td>
                    <td>
                        <div><strong>${vehicleText}</strong></div>
                        <div style="font-size: 0.85rem; color: #666;">${plate}</div>
                    </td>
                    <td>
                        <div style="margin-bottom: 4px;">${approvalHtml}</div>
                        <div>${statusHtml}</div>
                    </td>
                    <td class="text-end">
                        <button class="btn btn-outline-primary btn-sm btn-details" data-id="${c.id}">Detay / İstatistikler</button>
                    </td>
                </tr>
            `;
        });
        tbody.innerHTML = html;
        
    } catch(e) {
        tbody.innerHTML = `<tr><td colspan="5" class="text-center py-4 text-danger">Sunucu hatası: ${e.message}</td></tr>`;
    }
}

async function openDetailsModal(id) {
    document.getElementById('stats-modal-overlay').style.display = 'flex';
    document.getElementById('modal-courier-name').innerText = 'Yükleniyor...';
    
    // Reset values
    document.getElementById('modal-stat-delivered').innerText = '...';
    document.getElementById('modal-stat-cancelled').innerText = '...';
    document.getElementById('modal-stat-earnings').innerText = '...';
    document.getElementById('courier-map').style.display = 'none';
    document.getElementById('map-fallback-text').style.display = 'block';
    document.getElementById('map-fallback-text').innerText = 'Harita yükleniyor...';

    try {
        const res = await fetch(`${baseUrl}/api/admin/courier-stats/${id}`, { credentials: 'include' });
        const result = await res.json();
        
        if(!result.success) {
            alert(result.message || 'Hata oluştu');
            document.getElementById('stats-modal-overlay').style.display = 'none';
            return;
        }

        const data = result.data;
        document.getElementById('modal-courier-name').innerText = data.user.fullname + " Profili";
        document.getElementById('modal-stat-delivered').innerText = data.stats.totalDelivered;
        document.getElementById('modal-stat-cancelled').innerText = data.stats.totalCancelled;
        document.getElementById('modal-stat-earnings').innerText = data.stats.totalEstimatedEarnings.toFixed(2) + " TL";

        const lat = parseFloat(data.user.last_latitude);
        const lng = parseFloat(data.user.last_longitude);

        if(!Number.isNaN(lat) && !Number.isNaN(lng)) {
            document.getElementById('map-fallback-text').style.display = 'none';
            document.getElementById('courier-map').style.display = 'block';
            
            if(mapInstance) {
                mapInstance.off();
                mapInstance.remove();
                mapInstance = null;
            }
            
            // Wait slightly for modal to display so map container size is initialized
            setTimeout(() => {
                mapInstance = L.map('courier-map').setView([lat, lng], 15);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 }).addTo(mapInstance);
                
                const icon = L.divIcon({
                    html: '<div style="font-size:24px; background:white; border-radius:50%; width:32px; height:32px; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 5px rgba(0,0,0,0.3);">🛵</div>',
                    className: '',
                    iconSize: [32, 32],
                    iconAnchor: [16, 16]
                });
                
                mapMarker = L.marker([lat, lng], {icon: icon}).addTo(mapInstance);
                mapMarker.bindPopup(`<strong>${data.user.fullname}</strong><br>Son Konumu`).openPopup();
                
                // Force size fix
                setTimeout(() => mapInstance.invalidateSize(), 50);
            }, 100);

        } else {
            document.getElementById('courier-map').style.display = 'none';
            document.getElementById('map-fallback-text').style.display = 'block';
            document.getElementById('map-fallback-text').innerText = 'Kurye henüz herhangi bir konum bildirisi yapmamış.';
        }
        
    } catch(e) {
        alert('Sunucu hatası: ' + e.message);
        document.getElementById('stats-modal-overlay').style.display = 'none';
    }
}

// === CUSTOM SELECT ===
function initCustomSelects() {
    document.querySelectorAll('.actions-bar select').forEach(select => {
        if (select.classList.contains('ys-select-original')) return;
        select.classList.add('ys-select-original');

        const wrapper = document.createElement('div');
        wrapper.className = 'ys-select-wrapper';
        select.parentNode.insertBefore(wrapper, select);
        wrapper.appendChild(select);

        const trigger = document.createElement('div');
        trigger.className = 'ys-select-trigger';
        trigger.innerHTML = `<span class="ys-select-text">${select.options[select.selectedIndex]?.text || ''}</span><span class="ys-select-arrow">▼</span>`;

        const panel = document.createElement('div');
        panel.className = 'ys-select-panel';
        panel.innerHTML = `
            <div class="ys-select-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" placeholder="Ara...">
            </div>
            <ul class="ys-select-list"></ul>
            <div class="ys-select-empty">Sonuç bulunamadı</div>
        `;

        wrapper.appendChild(trigger);
        wrapper.appendChild(panel);

        const list = panel.querySelector('.ys-select-list');
        const searchInput = panel.querySelector('input');
        const emptyMsg = panel.querySelector('.ys-select-empty');
        const textSpan = trigger.querySelector('.ys-select-text');

        const renderOptions = () => {
            list.innerHTML = '';
            Array.from(select.options).forEach(opt => {
                const li = document.createElement('li');
                li.textContent = opt.text;
                li.dataset.value = opt.value;
                if (opt.selected) li.classList.add('selected');
                li.addEventListener('click', e => {
                    e.stopPropagation();
                    select.value = opt.value;
                    textSpan.textContent = opt.text;
                    select.dispatchEvent(new Event('change', { bubbles: true }));
                    closePanel();
                    Array.from(list.children).forEach(c => c.classList.remove('selected'));
                    li.classList.add('selected');
                });
                list.appendChild(li);
            });
        };
        renderOptions();

        const openPanel = () => {
            document.querySelectorAll('.ys-select-panel.open').forEach(p => {
                p.classList.remove('open');
                p.parentNode.querySelector('.ys-select-trigger')?.classList.remove('open');
            });
            trigger.classList.add('open');
            panel.classList.add('open');
            searchInput.value = '';
            filterList('');
            setTimeout(() => searchInput.focus(), 50);
        };

        const closePanel = () => {
            trigger.classList.remove('open');
            panel.classList.remove('open');
        };

        trigger.addEventListener('click', e => {
            e.stopPropagation();
            panel.classList.contains('open') ? closePanel() : openPanel();
        });

        searchInput.addEventListener('input', e => filterList(e.target.value.trim().toLowerCase()));

        function filterList(query) {
            let hasVisible = false;
            Array.from(list.children).forEach(li => {
                const match = li.textContent.toLowerCase().includes(query);
                li.classList.toggle('hidden', !match);
                if (match) hasVisible = true;
            });
            emptyMsg.style.display = hasVisible ? 'none' : 'block';
        }

        document.addEventListener('click', e => { if (!wrapper.contains(e.target)) closePanel(); });
    });
}

document.addEventListener('DOMContentLoaded', () => {
    initCustomSelects();
    loadCouriers();

    document.getElementById('filter-form').addEventListener('submit', (e) => {
        e.preventDefault();
        loadCouriers();
    });

    document.getElementById('couriers-tbody').addEventListener('click', (e) => {
        const btn = e.target.closest('.btn-details');
        if(btn) {
            const id = btn.getAttribute('data-id');
            openDetailsModal(id);
        }
    });

    document.getElementById('modal-close').addEventListener('click', () => {
        document.getElementById('stats-modal-overlay').style.display = 'none';
    });
    document.getElementById('stats-modal-overlay').addEventListener('click', (e) => {
        if(e.target === document.getElementById('stats-modal-overlay')) {
            document.getElementById('stats-modal-overlay').style.display = 'none';
        }
    });
});
</script>
