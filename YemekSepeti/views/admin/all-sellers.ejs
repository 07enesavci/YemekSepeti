<script>
var baseUrl = (typeof window.getBaseUrl === 'function' ? window.getBaseUrl() : '') || '';

const statusFormat = {
    'pending': '⏳ Bekliyor',
    'confirmed': '✅ Onaylandı',
    'preparing': '🍳 Hazırlanıyor',
    'ready': '📦 Hazır',
    'on_delivery': '🛵 Dağıtımda',
    'delivered': '🎉 Teslim Edildi',
    'cancelled': '❌ İptal'
};

async function loadSellers() {
    const status = document.getElementById('filter-status').value;
    const search = document.getElementById('filter-search').value.trim();
    
    const tbody = document.getElementById('sellers-tbody');
    tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4">Yükleniyor...</td></tr>';
    
    let queryParams = new URLSearchParams();
    if(status && status !== 'all') queryParams.append('is_open', status);
    if(search) queryParams.append('search', search);

    try {
        const res = await fetch(`${baseUrl}/api/admin/all-sellers?${queryParams.toString()}`, { credentials: 'include' });
        const result = await res.json();
        
        if(!result.success || !result.data || result.data.length === 0) {
            tbody.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted">Arama kriterlerine uygun mağaza bulunamadı.</td></tr>';
            return;
        }

        let html = '';
        result.data.forEach(s => {
            const isApproved = s.Seller.is_active;
            const isOpen = s.Seller.is_open;
            
            const approvalHtml = isApproved 
                ? '<span style="color:#10B981; font-size:0.85rem; font-weight:bold;">✔ Onaylı Mağaza</span>' 
                : '<span style="color:#E74C3C; font-size:0.85rem; font-weight:bold;">⏳ Onay Bekliyor / Pasif</span>';

            const statusHtml = isOpen 
                ? '<span class="status-badge status-open">Sipariş Alıyor (Açık)</span>' 
                : '<span class="status-badge status-closed">Kapalı</span>';

            const rating = s.Seller.rating > 0 ? `⭐ ${s.Seller.rating} (${s.Seller.total_reviews} Değerlendirme)` : 'Henüz puan yok';

            html += `
                <tr class="align-middle">
                    <td>
                        <div style="font-weight: 600; color: var(--text-color); font-size: 1.05rem;">${s.Seller.shop_name}</div>
                        <div style="font-size: 0.85rem; color: #666; margin-top: 4px; display: flex; align-items: center; gap: 4px;"><span style="color:#dc2626;">📍</span> ${s.Seller.location && s.Seller.location !== 'Belirtilmedi' ? s.Seller.location : 'Adres belirtilmedi'}</div>
                        <div style="font-size: 0.85rem; color: #888; margin-top: 4px;">Katılım: ${new Date(s.created_at).toLocaleDateString('tr-TR')}</div>
                    </td>
                    <td>
                        <div><strong>${s.fullname}</strong></div>
                        <div style="color: #666; font-size: 0.85rem;">${s.email}</div>
                        <div style="color: #666; font-size: 0.85rem;">${s.phone || 'Telefon yok'}</div>
                    </td>
                    <td>
                        <div style="font-weight: bold; color: #F59E0B;">${rating}</div>
                    </td>
                    <td>
                        <div style="margin-bottom: 4px;">${approvalHtml}</div>
                        <div>${statusHtml}</div>
                    </td>
                    <td class="text-end">
                        <div style="display:flex; flex-direction:column; gap:6px; align-items:flex-end;">
                            <button class="btn btn-outline-primary btn-sm btn-details" style="min-width:160px;" data-id="${s.id}">Detay / İstatistikler</button>
                            <button class="btn btn-sm btn-media" style="min-width:160px;background:#dc2626;color:#fff;border:none;border-radius:8px;padding:5px 12px;font-size:0.82rem;font-weight:700;cursor:pointer;letter-spacing:0.3px;"
                                data-seller-id="${s.Seller.id}"
                                data-shop-name="${s.Seller.shop_name}"
                                data-logo="${s.Seller.logo_url || ''}"
                                data-banner="${s.Seller.banner_url || ''}">
                                Medya Yönet
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        });
        tbody.innerHTML = html;
        
    } catch(e) {
        tbody.innerHTML = `<tr><td colspan="5" class="text-center py-4 text-danger">Sunucu hatası: ${e.message}</td></tr>`;
    }
}

var currentModalSellerId = null;

async function openDetailsModal(id, startDate, endDate, showAll) {
    currentModalSellerId = id;
    document.getElementById('stats-modal-overlay').style.display = 'flex';
    document.getElementById('modal-seller-name').innerText = 'Yükleniyor...';
    
    // Reset values
    document.getElementById('modal-stat-delivered').innerText = '...';
    document.getElementById('modal-stat-cancelled').innerText = '...';
    document.getElementById('modal-stat-active').innerText = '...';
    document.getElementById('modal-stat-revenue').innerText = '...';
    document.getElementById('modal-recent-orders').innerHTML = '<tr><td colspan="4" class="text-center py-3">Yükleniyor...</td></tr>';

    // Set default dates if not provided and not showAll (son 30 gün)
    if (!showAll && !startDate && !endDate) {
        const now = new Date();
        const thirtyDaysAgo = new Date(now);
        thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
        startDate = thirtyDaysAgo.toISOString().slice(0, 10);
        endDate = now.toISOString().slice(0, 10);
    }

    document.getElementById('modal-start-date').value = startDate || '';
    document.getElementById('modal-end-date').value = endDate || '';

    let queryParams = new URLSearchParams();
    if (startDate) queryParams.append('startDate', startDate);
    if (endDate) queryParams.append('endDate', endDate);

    try {
        const res = await fetch(`${baseUrl}/api/admin/seller-stats/${id}?${queryParams.toString()}`, { credentials: 'include' });
        const result = await res.json();
        
        if(!result.success) {
            alert(result.message || 'Hata oluştu');
            document.getElementById('stats-modal-overlay').style.display = 'none';
            return;
        }

        const data = result.data;
        document.getElementById('modal-seller-name').innerText = data.user.shop_name + " Satış Raporu";
        document.getElementById('modal-stat-delivered').innerText = data.stats.totalDelivered;
        document.getElementById('modal-stat-cancelled').innerText = data.stats.totalCancelled;
        document.getElementById('modal-stat-active').innerText = data.stats.totalActive;
        document.getElementById('modal-stat-revenue').innerText = data.stats.totalRevenue.toLocaleString('tr-TR', { minimumFractionDigits: 2 }) + " TL";

        // Tarih aralığı başlığı
        const titleEl = document.getElementById('modal-orders-title');
        if (startDate && endDate) {
            const sd = new Date(startDate).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
            const ed = new Date(endDate).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
            titleEl.textContent = `📜 Sipariş Geçmişi (${sd} – ${ed}) — ${data.recentOrders?.length || 0} sipariş`;
        } else {
            titleEl.textContent = `📜 Sipariş Geçmişi (Tüm Zamanlar) — ${data.recentOrders?.length || 0} sipariş`;
        }

        let ordersHtml = '';
        if(data.recentOrders && data.recentOrders.length > 0) {
            data.recentOrders.forEach(o => {
                ordersHtml += `
                    <tr>
                        <td><strong>#${o.order_number}</strong></td>
                        <td>${new Date(o.created_at).toLocaleString('tr-TR')}</td>
                        <td><strong style="color:var(--primary-color);">${parseFloat(o.total_amount).toLocaleString('tr-TR', { minimumFractionDigits: 2 })} TL</strong></td>
                        <td>${statusFormat[o.status] || o.status}</td>
                    </tr>
                `;
            });
        } else {
            ordersHtml = '<tr><td colspan="4" class="text-center py-3 text-muted">Seçilen tarih aralığında sipariş kaydı bulunmuyor.</td></tr>';
        }
        document.getElementById('modal-recent-orders').innerHTML = ordersHtml;
        
    } catch(e) {
        alert('Sunucu hatası: ' + e.message);
        document.getElementById('stats-modal-overlay').style.display = 'none';
    }
}

// === CUSTOM SELECT ===
function initCustomSelects() {
    document.querySelectorAll('.actions-bar select').forEach(select => {
        if (select.classList.contains('ys-select-original')) return;
        select.classList.add('ys-select-original');

        const wrapper = document.createElement('div');
        wrapper.className = 'ys-select-wrapper';
        select.parentNode.insertBefore(wrapper, select);
        wrapper.appendChild(select);

        const trigger = document.createElement('div');
        trigger.className = 'ys-select-trigger';
        trigger.innerHTML = `<span class="ys-select-text">${select.options[select.selectedIndex]?.text || ''}</span><span class="ys-select-arrow">▼</span>`;

        const panel = document.createElement('div');
        panel.className = 'ys-select-panel';
        panel.innerHTML = `
            <div class="ys-select-search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" placeholder="Ara...">
            </div>
            <ul class="ys-select-list"></ul>
            <div class="ys-select-empty">Sonuç bulunamadı</div>
        `;

        wrapper.appendChild(trigger);
        wrapper.appendChild(panel);

        const list = panel.querySelector('.ys-select-list');
        const searchInput = panel.querySelector('input');
        const emptyMsg = panel.querySelector('.ys-select-empty');
        const textSpan = trigger.querySelector('.ys-select-text');

        const renderOptions = () => {
            list.innerHTML = '';
            Array.from(select.options).forEach(opt => {
                const li = document.createElement('li');
                li.textContent = opt.text;
                li.dataset.value = opt.value;
                if (opt.selected) li.classList.add('selected');
                li.addEventListener('click', e => {
                    e.stopPropagation();
                    select.value = opt.value;
                    textSpan.textContent = opt.text;
                    select.dispatchEvent(new Event('change', { bubbles: true }));
                    closePanel();
                    Array.from(list.children).forEach(c => c.classList.remove('selected'));
                    li.classList.add('selected');
                });
                list.appendChild(li);
            });
        };
        renderOptions();

        const openPanel = () => {
            document.querySelectorAll('.ys-select-panel.open').forEach(p => {
                p.classList.remove('open');
                p.parentNode.querySelector('.ys-select-trigger')?.classList.remove('open');
            });
            trigger.classList.add('open');
            panel.classList.add('open');
            searchInput.value = '';
            filterList('');
            setTimeout(() => searchInput.focus(), 50);
        };

        const closePanel = () => {
            trigger.classList.remove('open');
            panel.classList.remove('open');
        };

        trigger.addEventListener('click', e => {
            e.stopPropagation();
            panel.classList.contains('open') ? closePanel() : openPanel();
        });

        searchInput.addEventListener('input', e => filterList(e.target.value.trim().toLowerCase()));

        function filterList(query) {
            let hasVisible = false;
            Array.from(list.children).forEach(li => {
                const match = li.textContent.toLowerCase().includes(query);
                li.classList.toggle('hidden', !match);
                if (match) hasVisible = true;
            });
            emptyMsg.style.display = hasVisible ? 'none' : 'block';
        }

        document.addEventListener('click', e => { if (!wrapper.contains(e.target)) closePanel(); });
    });
}

// --- MEDYA MODAL ---
var currentMediaSellerId = null;

function setLogoPreview(url) {
    const box = document.getElementById('logo-preview-box');
    if (url) {
        box.innerHTML = `<img src="${url}" alt="Logo" onerror="this.parentElement.innerHTML='<div class=\\'no-media\\'>Resim yüklenemedi</div>'">`;
    } else {
        box.innerHTML = '<div class="no-media">Logo Yok</div>';
    }
}

function setBannerPreview(url) {
    const box = document.getElementById('banner-preview-box');
    if (url) {
        box.innerHTML = `<img src="${url}" alt="Banner" onerror="this.parentElement.innerHTML='<div class=\\'no-media\\'>Resim yüklenemedi</div>'">`;
    } else {
        box.innerHTML = '<div class="no-media">Banner Yok</div>';
    }
}

function openMediaModal(sellerId, shopName, logoUrl, bannerUrl) {
    currentMediaSellerId = sellerId;
    document.getElementById('media-modal-title').textContent = shopName + ' — Medya Yönetimi';
    document.getElementById('logo-status-msg').textContent = '';
    document.getElementById('banner-status-msg').textContent = '';
    document.getElementById('logo-file-input').value = '';
    document.getElementById('banner-file-input').value = '';
    setLogoPreview(logoUrl);
    setBannerPreview(bannerUrl);
    document.getElementById('media-modal-overlay').style.display = 'flex';
}

function showMediaStatus(elId, msg, ok) {
    const el = document.getElementById(elId);
    el.textContent = msg;
    el.style.color = ok ? '#10B981' : '#dc2626';
}

document.addEventListener('DOMContentLoaded', () => {
    initCustomSelects();
    loadSellers();

    document.getElementById('filter-form').addEventListener('submit', (e) => {
        e.preventDefault();
        loadSellers();
    });

    document.getElementById('sellers-tbody').addEventListener('click', (e) => {
        const detailsBtn = e.target.closest('.btn-details');
        if (detailsBtn) {
            openDetailsModal(detailsBtn.getAttribute('data-id'));
        }
        const mediaBtn = e.target.closest('.btn-media');
        if (mediaBtn) {
            openMediaModal(
                mediaBtn.getAttribute('data-seller-id'),
                mediaBtn.getAttribute('data-shop-name'),
                mediaBtn.getAttribute('data-logo'),
                mediaBtn.getAttribute('data-banner')
            );
        }
    });

    // Medya Modal kapat
    document.getElementById('media-modal-close').addEventListener('click', () => {
        document.getElementById('media-modal-overlay').style.display = 'none';
    });
    document.getElementById('media-modal-overlay').addEventListener('click', (e) => {
        if (e.target === document.getElementById('media-modal-overlay')) {
            document.getElementById('media-modal-overlay').style.display = 'none';
        }
    });

    // Logo yükleme
    document.getElementById('logo-file-input').addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file || !currentMediaSellerId) return;
        showMediaStatus('logo-status-msg', 'Yükleniyor...', true);
        const formData = new FormData();
        formData.append('logo', file);
        try {
            const res = await fetch(`${baseUrl}/api/upload/admin/seller-logo/${currentMediaSellerId}`, {
                method: 'POST', credentials: 'include', body: formData
            });
            const result = await res.json();
            if (result.success) {
                setLogoPreview(result.url);
                showMediaStatus('logo-status-msg', 'Logo başarıyla güncellendi.', true);
                loadSellers();
            } else {
                showMediaStatus('logo-status-msg', result.message || 'Yükleme başarısız.', false);
            }
        } catch (err) {
            showMediaStatus('logo-status-msg', 'Sunucu hatası: ' + err.message, false);
        }
        e.target.value = '';
    });

    // Banner yükleme
    document.getElementById('banner-file-input').addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file || !currentMediaSellerId) return;
        showMediaStatus('banner-status-msg', 'Yükleniyor...', true);
        const formData = new FormData();
        formData.append('banner', file);
        try {
            const res = await fetch(`${baseUrl}/api/upload/admin/seller-banner/${currentMediaSellerId}`, {
                method: 'POST', credentials: 'include', body: formData
            });
            const result = await res.json();
            if (result.success) {
                setBannerPreview(result.url);
                showMediaStatus('banner-status-msg', 'Banner başarıyla güncellendi.', true);
                loadSellers();
            } else {
                showMediaStatus('banner-status-msg', result.message || 'Yükleme başarısız.', false);
            }
        } catch (err) {
            showMediaStatus('banner-status-msg', 'Sunucu hatası: ' + err.message, false);
        }
        e.target.value = '';
    });

    // Logo kaldır
    document.getElementById('logo-remove-btn').addEventListener('click', async () => {
        if (!currentMediaSellerId) return;
        if (!confirm('Bu satıcının logosunu kaldırmak istediğinizden emin misiniz?')) return;
        showMediaStatus('logo-status-msg', 'Kaldırılıyor...', true);
        try {
            const res = await fetch(`${baseUrl}/api/admin/seller/${currentMediaSellerId}/remove-logo`, {
                method: 'DELETE', credentials: 'include'
            });
            const result = await res.json();
            if (result.success) {
                setLogoPreview(null);
                showMediaStatus('logo-status-msg', 'Logo kaldırıldı.', true);
                loadSellers();
            } else {
                showMediaStatus('logo-status-msg', result.message || 'İşlem başarısız.', false);
            }
        } catch (err) {
            showMediaStatus('logo-status-msg', 'Sunucu hatası: ' + err.message, false);
        }
    });

    // Banner kaldır
    document.getElementById('banner-remove-btn').addEventListener('click', async () => {
        if (!currentMediaSellerId) return;
        if (!confirm('Bu satıcının bannerını kaldırmak istediğinizden emin misiniz?')) return;
        showMediaStatus('banner-status-msg', 'Kaldırılıyor...', true);
        try {
            const res = await fetch(`${baseUrl}/api/admin/seller/${currentMediaSellerId}/remove-banner`, {
                method: 'DELETE', credentials: 'include'
            });
            const result = await res.json();
            if (result.success) {
                setBannerPreview(null);
                showMediaStatus('banner-status-msg', 'Banner kaldırıldı.', true);
                loadSellers();
            } else {
                showMediaStatus('banner-status-msg', result.message || 'İşlem başarısız.', false);
            }
        } catch (err) {
            showMediaStatus('banner-status-msg', 'Sunucu hatası: ' + err.message, false);
        }
    });

    document.getElementById('modal-close').addEventListener('click', () => {
        document.getElementById('stats-modal-overlay').style.display = 'none';
    });
    document.getElementById('stats-modal-overlay').addEventListener('click', (e) => {
        if(e.target === document.getElementById('stats-modal-overlay')) {
            document.getElementById('stats-modal-overlay').style.display = 'none';
        }
    });

    // Modal tarih filtresi
    document.getElementById('modal-filter-btn').addEventListener('click', () => {
        if (!currentModalSellerId) return;
        const sd = document.getElementById('modal-start-date').value;
        const ed = document.getElementById('modal-end-date').value;
        if (!sd || !ed) {
            alert('Lütfen başlangıç ve bitiş tarihlerini seçin.');
            return;
        }
        if (new Date(sd) > new Date(ed)) {
            alert('Başlangıç tarihi bitiş tarihinden sonra olamaz.');
            return;
        }
        openDetailsModal(currentModalSellerId, sd, ed);
    });

    document.getElementById('modal-clear-filter-btn').addEventListener('click', () => {
        if (!currentModalSellerId) return;
        openDetailsModal(currentModalSellerId, null, null, true);
    });
});
</script>
