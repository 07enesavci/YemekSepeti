<script>
    var pendingSellersList = [];

    function openDocModal(sellerId) {
        var seller = pendingSellersList.find(function(s) { return s.id == sellerId; });
        if (!seller) return;
        var base = window.location.origin || (window.location.protocol + '//' + window.location.host);
        var body = document.getElementById('doc-modal-body');
        var docs = [
            { key: 'tax_plate', label: 'Vergi Levhası' },
            { key: 'id_card', label: 'Kimlik Fotokopisi' },
            { key: 'activity_cert', label: 'Faaliyet Belgesi / Esnaf Odası Kaydı' },
            { key: 'business_license', label: 'İşyeri Ruhsatı' }
        ];
        var user = seller.user || seller.User;
        var email = user ? user.email : '';
        var html = '<p style="margin-bottom: 1rem;"><strong>' + (seller.shop_name || '') + '</strong> – ' + email + '</p>';
        docs.forEach(function(d) {
            var path = seller[d.key];
            var url = path ? (path.indexOf('http') === 0 ? path : base + path) : null;
            html += '<div class="doc-item">';
            html += '<label>' + d.label + '</label>';
            if (url) {
                html += '<a href="' + url + '" target="_blank" rel="noopener">Belgeyi yeni sekmede aç</a>';
                var ext = (path.split('.').pop() || '').split('?')[0].toLowerCase();
                if (['jpg','jpeg','png','gif','webp'].indexOf(ext) !== -1) {
                    html += '<img src="' + url + '" alt="' + d.label + '" loading="lazy">';
                }
            } else {
                html += '<span class="no-doc">Yüklenmemiş</span>';
            }
            html += '</div>';
        });
        body.innerHTML = html;
        document.getElementById('doc-modal-overlay').style.display = 'flex';
    }

