<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css?v=20260629-mobilefix1">
<link rel="stylesheet" href="/assets/css/pages/courier-history.css">

<div class="panel-layout">
    
    <%- include('../partials/sidebar') %>

    <main class="panel-content">
        
        <h1 class="panel-title">Teslimat Geçmişi ve Kazançlar</h1>
        
        <div class="stat-grid">
            <div class="card stat-card">
                <span class="stat-icon">💰</span>
                <span class="stat-label">Toplam Bakiye</span>
                <strong class="stat-value">0.00 TL</strong>
            </div>
            <div class="card stat-card">
                <span class="stat-icon">✅</span>
                <span class="stat-label">Toplam Teslimat</span>
                <strong class="stat-value">0</strong>
            </div>
        </div>

        <div class="card" style="margin-top: 2rem;">
            <div class="card-content">
                <h3 class="checkout-card-title">Son İşlemler</h3>
                
                <div class="transaction-list">
                    <p class="text-muted" style="text-align: center; padding: 2rem;">Yükleniyor...</p>
                </div>
            </div>
        </div>

    </main>
</div>

<!-- Sipariş detay modal -->
<div id="courier-order-detail-modal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 9999; align-items: center; justify-content: center; padding: 1rem;">
    <div style="background: #fff; border-radius: 12px; max-width: 540px; width: 100%; max-height: 90vh; overflow-y: auto; padding: 1.5rem; box-shadow: 0 8px 32px rgba(0,0,0,0.3);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; border-bottom: 1px solid #eee; padding-bottom: 0.75rem;">
            <h3 id="courier-detail-modal-title" style="margin:0; font-size:1.1rem; color:#2c3e50;">Sipariş Detayı</h3>
            <button type="button" id="courier-detail-modal-close" style="background:#e74c3c;color:#fff;border:none;border-radius:6px;padding:4px 12px;cursor:pointer;font-size:0.9rem;">✕ Kapat</button>
        </div>
        <div id="courier-detail-modal-body" style="color:#333; font-size:0.95rem; line-height:1.6;">
            <p style="color:#888;">Yükleniyor...</p>
        </div>
    </div>
</div>
