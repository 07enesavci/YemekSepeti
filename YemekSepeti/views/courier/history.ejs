<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css?v=20260629-mobilefix1">
<link rel="stylesheet" href="/assets/css/pages/courier-history.css">

<div class="panel-layout">
    
    <%- include('../partials/sidebar') %>

    <main class="panel-content">
        
        <h1 class="panel-title">Teslimat Geçmişi ve Kazançlar</h1>
        
        <div class="stat-grid">
            <div class="card stat-card">
                <span class="stat-icon">💰</span>
                <span class="stat-label">Toplam Bakiye</span>
                <strong class="stat-value">0.00 TL</strong>
            </div>
            <div class="card stat-card">
                <span class="stat-icon">✅</span>
                <span class="stat-label">Toplam Teslimat</span>
                <strong class="stat-value">0</strong>
            </div>
        </div>

        <div class="card" style="margin-top: 2rem;">
            <div class="card-content">
                <h3 class="checkout-card-title">Son İşlemler</h3>
                
                <div class="transaction-list">
                    <p class="text-muted" style="text-align: center; padding: 2rem;">Yükleniyor...</p>
                </div>
            </div>
        </div>

    </main>
</div>

<!-- Sipariş detay modal -->
<div id="courier-order-detail-modal" class="courier-detail-overlay" style="display: none;">
    <div class="courier-detail-dialog">
        <div class="courier-detail-head">
            <h3 id="courier-detail-modal-title" class="courier-detail-title">Sipariş Detayı</h3>
            <button type="button" id="courier-detail-modal-close" class="courier-detail-close" aria-label="Kapat">✕ Kapat</button>
        </div>
        <div id="courier-detail-modal-body" class="courier-detail-body">
            <p class="text-muted">Yükleniyor...</p>
        </div>
    </div>
</div>
