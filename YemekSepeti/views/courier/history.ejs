<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css">
<link rel="stylesheet" href="/assets/css/pages/courier-history.css">

<div class="panel-layout">
    
    <%- include('../partials/sidebar') %>

    <main class="panel-content">
        
        <h1 class="panel-title">Teslimat Geçmişi ve Kazançlar</h1>
        
        <div class="stat-grid">
            <div class="card stat-card">
                <span class="stat-icon">💰</span>
                <span class="stat-label">Toplam Bakiye</span>
                <strong class="stat-value">0.00 TL</strong>
            </div>
            <div class="card stat-card">
                <span class="stat-icon">✅</span>
                <span class="stat-label">Toplam Teslimat</span>
                <strong class="stat-value">0</strong>
            </div>
        </div>

        <div class="card" style="margin-top: 2rem;">
            <div class="card-content">
                <h3 class="checkout-card-title">Son İşlemler</h3>
                
                <div class="transaction-list">
                    <p class="text-muted" style="text-align: center; padding: 2rem;">Yükleniyor...</p>
                </div>
            </div>
        </div>

    </main>
</div>

<!-- Sipariş detay modal -->
<div id="courier-order-detail-modal" class="modal-overlay" style="display: none;">
    <div class="modal-content" style="max-width: 520px;">
        <div class="card">
            <div class="card-content">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                    <h3 class="checkout-card-title" id="courier-detail-modal-title">Sipariş Detayı</h3>
                    <button type="button" class="btn btn-secondary btn-sm" id="courier-detail-modal-close">Kapat</button>
                </div>
                <div id="courier-detail-modal-body">
                    <p class="text-muted">Yükleniyor...</p>
                </div>
            </div>
        </div>
    </div>
</div>
<style>
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; align-items: center; justify-content: center; padding: 1rem; }
.modal-overlay .modal-content { width: 100%; max-height: 90vh; overflow-y: auto; }
</style>