<link rel="stylesheet" href="/assets/css/pages/payment-cards.css">

<div class="container section-padding">
    <h1 class="section-title">Siparişi Tamamla</h1>

    <div class="checkout-layout">
        
        <div class="checkout-details">
            
            <div class="card checkout-card">
                <h3 class="checkout-card-title">1. Teslimat Adresi</h3>
                <div class="role-selector"> 
                    <div class="form-check form-check-radio">
                        <input type="radio" id="address-1" name="address" value="1" checked>
                        <label for="address-1">
                            <strong>Ev Adresi</strong>
                            <span>(Çerkezköy, Tekirdağ...)</span>
                        </label>
                    </div>
                    <div class="form-check form-check-radio">
                        <input type="radio" id="address-new" name="address" value="new">
                        <label for="address-new">
                            <strong>Yeni Adres Ekle</strong>
                        </label>
                    </div>
                </div>
            </div>

            <div class="card checkout-card">
                <h3 class="checkout-card-title">2. Ödeme Yöntemi</h3>
                <div class="role-selector">
                    <div class="form-check form-check-radio">
                        <input type="radio" id="card-1" name="payment-card" value="1" checked>
                        <label for="card-1">
                            <strong>💳 **** **** **** 1234</strong>
                        </label>
                    </div>
                    <div class="form-check form-check-radio">
                        <input type="radio" id="card-new" name="payment-card" value="new">
                        <label for="card-new">
                            <strong>Yeni Kart Ekle</strong>
                        </label>
                    </div>
                </div>

                <form id="new-card-form" class="checkout-new-card-form" style="display: none; margin-top: 1.5rem;">
                    <div class="cc-anim-wrapper">
                        <section class="cc-anim-card" id="checkout-cc-card">
                            <div class="cc-anim-highlight hl-hidden" id="checkout-cc-highlight"></div>
                            <section class="cc-anim-front">
                                <div class="cc-anim-header">
                                    <span style="font-size:13px;opacity:.85;">Kredi Kartı</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" height="36" width="54" viewBox="-96 -98.908 832 593.448">
                                        <path fill="#ff5f00" d="M224.833 42.298h190.416v311.005H224.833z"/>
                                        <path d="M244.446 197.828a197.448 197.448 0 0175.54-155.475 197.777 197.777 0 100 311.004 197.448 197.448 0 01-75.54-155.53z" fill="#eb001b"/>
                                        <path d="M640 197.828a197.777 197.777 0 01-320.015 155.474 197.777 197.777 0 000-311.004A197.777 197.777 0 01640 197.773z" fill="#f79e1b"/>
                                    </svg>
                                </div>
                                <div class="cc-anim-number" id="checkout-cc-number">
                                    <span>#<br/></span><span>#<br/></span><span>#<br/></span><span>#<br/></span>
                                    <span>#<br/></span><span>#<br/></span><span>#<br/></span><span>#<br/></span>
                                    <span>#<br/></span><span>#<br/></span><span>#<br/></span><span>#<br/></span>
                                    <span>#<br/></span><span>#<br/></span><span>#<br/></span><span>#<br/></span>
                                </div>
                                <div class="cc-anim-footer">
                                    <div>
                                        <div class="cc-anim-section-title">Kart Sahibi</div>
                                        <div id="checkout-cc-holder" style="text-transform:uppercase;font-size:14px;">Ad Soyad</div>
                                    </div>
                                    <div>
                                        <div class="cc-anim-section-title">SKT</div>
                                        <span id="checkout-cc-month" style="font-size:14px;">AA</span>/<span id="checkout-cc-year" style="font-size:14px;">YY</span>
                                    </div>
                                </div>
                            </section>
                            <section class="cc-anim-back">
                                <div class="cc-anim-hide-line"></div>
                                <div class="cc-anim-cvv-block">
                                    <span>CVV</span>
                                    <div class="cc-anim-cvv-field" id="checkout-cc-cvv"></div>
                                </div>
                            </section>
                        </section>
                    </div>
                    <div class="form-group">
                        <label for="card-name" class="form-label">Kart Üzerindeki İsim</label>
                        <input type="text" id="card-name" class="form-input" autocomplete="cc-name">
                    </div>
                    <div class="form-group">
                        <label for="card-number" class="form-label">Kart Numarası</label>
                        <input type="text" id="card-number" class="form-input" placeholder="0000 0000 0000 0000" inputmode="numeric" autocomplete="cc-number">
                    </div>
                    <div class="form-row"> 
                        <div class="form-group">
                            <label for="card-expiry" class="form-label">Son Kul. Tarihi</label>
                            <input type="text" id="card-expiry" class="form-input" placeholder="AA/YY" autocomplete="cc-exp">
                        </div>
                        <div class="form-group">
                            <label for="card-cvc" class="form-label">CVV</label>
                            <input type="text" id="card-cvc" class="form-input" placeholder="123" maxlength="3" autocomplete="cc-csc">
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-check form-check-inline">
                            <input type="checkbox" id="card-save-default">
                            <span>Varsayılan kart olarak kaydet</span>
                        </label>
                    </div>
                    <div class="checkout-new-card-actions">
                        <button type="button" class="btn btn-primary" id="checkout-save-card-btn">Kaydet</button>
                        <span class="checkout-save-hint">Kartı kaydetmeden sadece bu sipariş için de kullanabilirsiniz; siparişi tamamlayınca bilgiler iyzico ile işlenir.</span>
                    </div>
                </form>
            </div>

        </div> 

        <aside class="order-summary">
            <div class="card">
                <div class="card-content">
                    <h3 class="card-title">Sipariş Özeti</h3>
                    
                    <div class="summary-row">
                        <span>Ara Toplam</span>
                        <span id="summary-subtotal">0.00 TL</span>
                    </div>
                    <div class="summary-row">
                        <span>Teslimat Ücreti</span>
                        <span id="summary-delivery">29.99 TL</span>
                    </div>
                    
                    <hr class="divider">
                    
                    <div class="summary-row total-row">
                        <span>Toplam Tutar</span>
                        <strong id="summary-total" class="total-price">29.99 TL</strong>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" id="terms" required>
                            <label for="terms"><a href="/terms">Sözleşmeleri</a> okudum, onaylıyorum.</label>
                        </div>
                    </div>

                    <a href="#" class="btn btn-primary btn-full" id="complete-order-btn">
                        Siparişi Tamamla
                    </a>
                </div>
            </div>
        </aside>

    </div> 
</div>