<link rel="stylesheet" href="/assets/css/pages/seller-profile.css">

<section class="seller-header">
    <div class="seller-banner" id="seller-banner-img" style="background:#f0f0f0;min-height:180px;display:flex;align-items:center;justify-content:center;">
        <div class="ys-skeleton" style="width:100%;height:180px;border-radius:0;"></div>
    </div>
    <div class="container seller-info-container">
        <div class="seller-details">
            <img id="seller-logo-img" src="" alt="Satıcı Logosu" class="seller-logo" style="display:none;">
            <div class="seller-logo-skeleton ys-skeleton ys-skeleton-circle" style="width:80px;height:80px;" id="seller-logo-skeleton"></div>
            <div class="seller-info">
                <h1 id="seller-name"><span class="ys-skeleton ys-skeleton-text medium" style="display:inline-block;width:200px;">&nbsp;</span></h1>
                <p id="seller-rating"><span class="ys-skeleton ys-skeleton-text short" style="display:inline-block;width:140px;">&nbsp;</span></p>
            </div>
        </div>
    </div>
</section>

<div class="container section-padding">
    <div class="tabs">
        <button class="tab-link active" data-tab="menu">Menü</button>
        <button class="tab-link" data-tab="reviews">Yorumlar</button>
    </div>

    <div id="menu-content" class="tab-content active">
        <div id="menu-list-container">
            <!-- Skeleton kartları yükleme öncesi -->
            <div class="ys-skeleton-card ys-skeleton"><div class="ys-skeleton-img"></div><div class="ys-skeleton-text medium"></div><div class="ys-skeleton-text short"></div></div>
            <div class="ys-skeleton-card ys-skeleton"><div class="ys-skeleton-img"></div><div class="ys-skeleton-text medium"></div><div class="ys-skeleton-text short"></div></div>
            <div class="ys-skeleton-card ys-skeleton"><div class="ys-skeleton-img"></div><div class="ys-skeleton-text medium"></div><div class="ys-skeleton-text short"></div></div>
        </div>
    </div>

    <div id="reviews-content" class="tab-content" style="display: none;">
        <div id="reviews-list-container">
            <div class="card"><div class="card-content" style="text-align:center;padding:3rem 2rem;">
                <div class="ys-skeleton ys-skeleton-text medium" style="margin:0 auto 0.5rem;"></div>
                <div class="ys-skeleton ys-skeleton-text short" style="margin:0 auto;"></div>
            </div></div>
        </div>
    </div>
</div>
