<link rel="stylesheet" href="/assets/css/pages/order-confirmation.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="container section-padding">
    <div class="order-confirmation-wrapper">
        <div class="order-confirmation-card">
            <div class="confirmation-header">
                <div class="success-icon" style="color: #FFFFFF !important; opacity: 1 !important;">✓</div>
                <h1 class="confirmation-title" style="color: #FFFFFF !important; text-shadow: 0px 0px 1px #FFFFFF;">Siparişiniz Oluşturuldu!</h1>
                <p class="confirmation-subtitle" style="color: #FFFFFF !important; opacity: 1 !important;">Siparişiniz başarıyla alındı ve işleme alındı.</p>
            </div>

            <div class="confirmation-content">
                <div class="info-section">
                    <h2 class="section-title">Sipariş Bilgileri</h2>
                    <div id="loading-message" style="text-align: center; padding: 2rem; color: #666;">
                        <p>Sipariş bilgileri yükleniyor...</p>
                    </div>
                    <div id="order-info" style="display: none;">
                    <div class="info-item">
                        <div class="info-label">
                            <span class="info-icon">📦</span>
                            <span>Sipariş ID</span>
                        </div>
                        <div class="info-value" id="order-number">-</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">
                            <span class="info-icon">🏪</span>
                            <span>Restoran</span>
                        </div>
                        <div class="info-value" id="restaurant-name">-</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">
                            <span class="info-icon">📍</span>
                            <span>Teslimat Adresi</span>
                        </div>
                        <div class="info-value" id="delivery-address">-</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">
                            <span class="info-icon">💰</span>
                            <span>Toplam Tutar</span>
                        </div>
                        <div class="info-value total-amount" id="total-amount">-</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">
                            <span class="info-icon">📅</span>
                            <span>Sipariş Tarihi</span>
                        </div>
                        <div class="info-value" id="order-date">-</div>
                    </div>

                    <div class="order-status-steps" id="order-status-steps" style="display: none; margin-top: 1.5rem; padding: 1rem; background: var(--bg-accent, #f8f9fa); border-radius: 8px;">
                        <h3 class="section-title" style="font-size: 1rem; margin-bottom: 0.75rem;">Sipariş Takibi</h3>
                        <p class="status-current-text" id="status-current-text" style="font-weight: 600; margin-bottom: 0.75rem; color: var(--primary, #e74c3c);"></p>
                        <div class="status-steps-bar" role="status" aria-live="polite">
                            <div class="status-step" id="step-received"><span class="step-dot"></span><span>Sipariş alındı</span></div>
                            <div class="status-step" id="step-preparing"><span class="step-dot"></span><span>Hazırlanıyor</span></div>
                            <div class="status-step" id="step-ondelivery"><span class="step-dot"></span><span>Yolda</span></div>
                            <div class="status-step" id="step-delivered"><span class="step-dot"></span><span>Teslim edildi</span></div>
                        </div>
                        <p class="status-cancelled-msg" id="status-cancelled-msg" style="display: none; color: #dc3545; margin-top: 0.5rem;">Sipariş iptal edildi.</p>
                        <div id="order-tracking-map" style="display: none; margin-top: 1rem; height: 260px; border-radius: 8px; overflow: hidden; border: 1px solid var(--border-color, #eee);"></div>
                    </div>
                    </div>
                </div>

                <div class="action-buttons">
                    <a href="/buyer/orders" class="btn btn-primary">Siparişlerimi Görüntüle</a>
                    <a href="/" class="btn btn-secondary">Ana Sayfaya Dön</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', async function() {
    // EJS'den gelen orderId'yi kullan
    const orderId = "<%= typeof orderId !== 'undefined' ? orderId : '' %>" || null;
    
    if (!orderId) {
        // OrderId yoksa siparişler sayfasına yönlendir
        window.location.href = '/buyer/orders';
        return;
    }
    
    try {
        const baseUrl = window.getBaseUrl ? window.getBaseUrl() : '';
        const apiUrl = `${baseUrl}/api/orders/${orderId}`;
        console.log('📦 Sipariş bilgileri yükleniyor:', apiUrl);
        console.log('📦 Order ID:', orderId);
        
        const response = await fetch(apiUrl, {
            credentials: 'include'
        });
        
        console.log('📦 Response status:', response.status, response.statusText);
        
        if (!response.ok) {
            let errorData;
            try {
                errorData = await response.json();
            } catch (e) {
                errorData = { message: await response.text() };
            }
            console.error('❌ API hatası:', response.status, errorData);
            throw new Error(errorData.message || `Sipariş bilgileri yüklenemedi: ${response.status}`);
        }
        
        const data = await response.json();
        console.log('📦 API yanıtı:', data);
        
        if (!data.success || !data.data) {
            console.error('❌ Sipariş bulunamadı veya veri formatı hatalı:', data);
            throw new Error(data.message || 'Sipariş bulunamadı');
        }
        
        const order = data.data;
        
        // Loading mesajını gizle, order info'yu göster
        const loadingEl = document.getElementById('loading-message');
        const orderInfoEl = document.getElementById('order-info');
        if (loadingEl) loadingEl.style.display = 'none';
        if (orderInfoEl) orderInfoEl.style.display = 'block';
        
        // Bilgileri doldur
        const orderNumberEl = document.getElementById('order-number');
        const restaurantEl = document.getElementById('restaurant-name');
        const addressEl = document.getElementById('delivery-address');
        const totalEl = document.getElementById('total-amount');
        const dateEl = document.getElementById('order-date');
        
        if (orderNumberEl) {
            orderNumberEl.textContent = order.orderNumber || `#${order.id}`;
        }
        
        if (restaurantEl) {
            restaurantEl.textContent = order.seller?.name || 'Restoran bilgisi yok';
        }
        
        if (addressEl) {
            const address = order.address;
            if (address && address.full) {
                addressEl.textContent = address.full;
            } else if (address && address.addressLine) {
                addressEl.textContent = `${address.addressLine}, ${address.district || ''}, ${address.city || ''}`;
            } else {
                addressEl.textContent = 'Adres bilgisi yok';
            }
        }
        
        if (totalEl) {
            const formatTL = window.formatTL || ((amount) => {
                return Number(amount || 0).toLocaleString('tr-TR', {
                    style: 'currency',
                    currency: 'TRY'
                });
            });
            totalEl.textContent = formatTL(order.total);
        }
        
        if (dateEl) {
            dateEl.textContent = order.date || new Date().toLocaleString('tr-TR');
        }

        // Sipariş takibi: durum adımlarını canlı güncelle
        var statusStepsEl = document.getElementById('order-status-steps');
        var statusCurrentText = document.getElementById('status-current-text');
        var statusLabels = { pending: 'Sipariş alındı', confirmed: 'Hazırlanıyor', preparing: 'Hazırlanıyor', ready: 'Hazırlanıyor', on_delivery: 'Yolda', delivered: 'Teslim edildi', cancelled: 'İptal edildi' };

        function renderTrackingStatus(currentStatus) {
            if (!statusStepsEl || !currentStatus) return;
            statusStepsEl.style.display = 'block';
            var status = (currentStatus || '').toLowerCase();
            if (statusCurrentText) statusCurrentText.textContent = 'Şu an: ' + (statusLabels[status] || currentStatus || 'Bekleniyor');
            var cancelledMsg = document.getElementById('status-cancelled-msg');
            if (status === 'cancelled') {
                if (cancelledMsg) cancelledMsg.style.display = 'block';
                return;
            }

            if (cancelledMsg) cancelledMsg.style.display = 'none';
            var stepIds = ['step-received', 'step-preparing', 'step-ondelivery', 'step-delivered'];
            var idx = 0;
            if (status === 'confirmed' || status === 'preparing' || status === 'ready') idx = 1;
            else if (status === 'on_delivery') idx = 2;
            else if (status === 'delivered') idx = 3;
            for (var s = 0; s < stepIds.length; s++) {
                var stepEl = document.getElementById(stepIds[s]);
                if (stepEl) {
                    stepEl.classList.remove('active', 'done');
                    if (s < idx) stepEl.classList.add('done');
                    else if (s === idx) stepEl.classList.add('active');
                }
            }
        }

        renderTrackingStatus(order.status);

        // Harita: teslimat adresi ve varsa kurye anlık konumu
        var mapDiv = document.getElementById('order-tracking-map');
        var addressLat = order.address && order.address.latitude != null ? parseFloat(order.address.latitude) : null;
        var addressLng = order.address && order.address.longitude != null ? parseFloat(order.address.longitude) : null;
        var courierLat = order.courierLatitude != null ? parseFloat(order.courierLatitude) : null;
        var courierLng = order.courierLongitude != null ? parseFloat(order.courierLongitude) : null;
        var showMap = (addressLat != null && addressLng != null) || (courierLat != null && courierLng != null);
        if (mapDiv && showMap && typeof L !== 'undefined') {
            mapDiv.style.display = 'block';
            var center = [addressLat || courierLat, addressLng || courierLng].filter(function(x) { return x != null; });
            if (center.length >= 2) {
                var map = L.map('order-tracking-map').setView(center, 14);
                window._orderTrackingMap = map;
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OSM', maxZoom: 19 }).addTo(map);
                if (addressLat != null && addressLng != null) L.marker([addressLat, addressLng]).addTo(map).bindPopup('Teslimat adresi');
                if (courierLat != null && courierLng != null) {
                    window._orderTrackingMarker = L.marker([courierLat, courierLng], { icon: L.divIcon({ className: 'courier-live-marker', html: '<div style="background:#2563EB;color:#fff;border-radius:50%;width:28px;height:28px;display:flex;align-items:center;justify-content:center;font-size:14px;">🛵</div>', iconSize: [28,28], iconAnchor: [14,14] }) }).addTo(map).bindPopup('Kurye konumu');
                }
                setTimeout(function() { map.invalidateSize(); }, 300);
            }
        }
        if (orderId && order.status !== 'delivered' && order.status !== 'cancelled') {
            window._orderTrackingOrderId = orderId;
            window._orderTrackingPoll = setInterval(async function() {
                if (!window._orderTrackingOrderId) return;
                try {
                    var r = await fetch((window.getBaseUrl ? window.getBaseUrl() : '') + '/api/orders/' + window._orderTrackingOrderId, { credentials: 'include' });
                    if (!r.ok) return;
                    var d = await r.json();
                    if (!d.success || !d.data) return;
                    var o = d.data;

                    renderTrackingStatus(o.status);

                    if (o.status === 'delivered' || o.status === 'cancelled') {
                        if (window._orderTrackingPoll) {
                            clearInterval(window._orderTrackingPoll);
                            window._orderTrackingPoll = null;
                        }
                    }

                    if (o.status !== 'on_delivery' && o.status !== 'delivered') return;
                    var clat = o.courierLatitude != null ? parseFloat(o.courierLatitude) : null;
                    var clng = o.courierLongitude != null ? parseFloat(o.courierLongitude) : null;
                    if (clat != null && clng != null && window._orderTrackingMap) {
                        if (window._orderTrackingMarker) window._orderTrackingMarker.setLatLng([clat, clng]);
                        else {
                            window._orderTrackingMarker = L.marker([clat, clng], { icon: L.divIcon({ className: 'courier-live-marker', html: '<div style="background:#2563EB;color:#fff;border-radius:50%;width:28px;height:28px;">🛵</div>', iconSize: [28,28], iconAnchor: [14,14] }) }).addTo(window._orderTrackingMap).bindPopup('Kurye konumu');
                        }
                    }
                } catch (e) {}
            }, 15000);
        }
        
    } catch (error) {
        console.error('Sipariş bilgileri yükleme hatası:', error);
        const loadingEl = document.getElementById('loading-message');
        if (loadingEl) {
            loadingEl.innerHTML = `
                <div style="color: #dc3545; padding: 1rem; background: #f8d7da; border-radius: 8px; margin-bottom: 1rem;">
                    <strong>Hata:</strong> ${error.message || 'Sipariş bilgileri yüklenirken bir hata oluştu.'}
                </div>
                <p>Siparişler sayfasına yönlendiriliyorsunuz...</p>
            `;
        }
        setTimeout(() => {
            window.location.href = '/buyer/orders';
        }, 3000);
    }
});
</script>

