<link rel="stylesheet" href="/assets/css/pages/auth.css">
<link rel="stylesheet" href="/assets/css/pages/checkout.css">

<div class="container section-padding">
    <h1 class="section-title">Hesabım</h1>

    <div class="profile-layout">
        
        <aside class="profile-sidebar">
            <nav class="profile-nav">
                <ul>
                    <li><a href="#profil-bilgileri" class="active">Profil Bilgileri</a></li>
                    <li><a href="/buyer/addresses">Adreslerim</a></li>
                    <li><a href="/buyer/wallet">Cüzdan & Kuponlar</a></li>
                    <li><a href="/buyer/orders">Siparişlerim</a></li> 
                    <li><a href="/buyer/security">Güvenlik</a></li>
                    <li><a href="#" id="logout-btn">Çıkış Yap</a></li>
                </ul>
            </nav>
        </aside>

        <div class="profile-content">
            
            <section id="profil-bilgileri" class="profile-section active">
                <div class="card">
                    <div class="card-content">
                        <h3 class="checkout-card-title">Profil Bilgileri</h3>
                        <form id="profile-info-form">
                            <div class="form-group">
                                <label for="profile-name" class="form-label">Ad Soyad</label>
                                <input type="text" id="profile-name" class="form-input" value="<%= user && user.fullname ? user.fullname : '' %>" required>
                            </div>
                            <div class="form-group">
                                <label for="profile-phone" class="form-label">Telefon Numarası</label>
                                <input type="tel" id="profile-phone" class="form-input" value="<%= user && user.phone ? user.phone : '' %>">
                            </div>
                            <div class="form-group">
                                <label for="profile-email" class="form-label">E-posta</label>
                                <input type="email" id="profile-email" class="form-input" value="<%= user && user.email ? user.email : '' %>" disabled>
                            </div>
                            <button type="submit" class="btn btn-primary">Bilgileri Güncelle</button>
                        </form>
                        
                        <hr class="divider" style="margin: 2rem 0 1rem;">
                        <div class="form-group">
                            <h4 style="margin-bottom: 0.5rem; color: #c0392b;">Hesabı Sil</h4>
                            <p class="text-muted" style="margin-bottom: 0.75rem; font-size: 0.9rem;">
                                Bu işlem geri alınamaz. Tüm hesabınız pasif hale getirilir ve tekrar giriş yapamazsınız.
                            </p>
                            <button type="button" class="btn btn-outline-danger" id="btn-delete-account">Hesabımı Kalıcı Olarak Sil</button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Adreslerim, Cüzdan, Güvenlik → ayrı sayfalara yönlendirilir (sidebar navdan) -->

        </div>
    </div>
</div>
<script>
(function() {
    async function doDeleteAccount() {
        var confirmed = await window.showConfirm('Hesabınızı kalıcı olarak silmek istediğinize emin misiniz? Bu işlem geri alınamaz.');
        if (!confirmed) return;
        var baseUrl = (typeof window.getBaseUrl === 'function' ? window.getBaseUrl() : '') || '';
        fetch(baseUrl + '/api/auth/delete-account', { method: 'DELETE', credentials: 'include' })
            .then(function(r) { return r.json().catch(function() { return {}; }).then(function(data) {
                if (r.ok && data.success) {
                    alert('Hesabınız silindi. Hoşçakalın.');
                    try { localStorage.clear(); sessionStorage.clear(); } catch (e) {}
                    window.location.href = baseUrl || '/';
                } else {
                    alert('Hesap silinemedi: ' + (data.message || r.status));
                }
            }); })
            .catch(function() { alert('Hesap silinirken bir hata oluştu.'); });
    }
    window.deleteMyAccount = doDeleteAccount;
    document.addEventListener('DOMContentLoaded', function() {
        var btn = document.getElementById('btn-delete-account');
        if (btn) btn.addEventListener('click', doDeleteAccount);
    });
})();
</script>