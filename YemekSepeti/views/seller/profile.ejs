<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css">
<link rel="stylesheet" href="/assets/css/pages/seller-profile-admin.css">

<div class="panel-layout">
    
    <%- include('../partials/sidebar') %>

    <main class="panel-content">
        
        <h1 class="panel-title">Dükkan Profili Yönetimi</h1>
        
        <div class="card">
            <div class="card-content">
                
                <form id="seller-profile-form">
                    
                    <div class="form-group profile-images">
                        <div class="image-uploader">
                            <label class="form-label">Dükkan Logosu</label>
                            <div style="margin-bottom: 10px;">
                                <label style="margin-right: 20px; cursor: pointer;">
                                    <input type="radio" name="logo-option" value="file" id="logo-option-file" checked> Dosya Seç
                                </label>
                                <label style="cursor: pointer;">
                                    <input type="radio" name="logo-option" value="url" id="logo-option-url"> URL Gir
                                </label>
                            </div>
                            <img src="" alt="Logo" id="logo-preview" class="logo-preview">
                            <div id="logo-file-container">
                                <input type="file" id="logo-upload" class="file-input">
                                <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                                    <label for="logo-upload" class="btn btn-secondary btn-sm">Resim Seç</label>
                                    <button type="button" id="remove-logo-btn" class="btn btn-secondary btn-sm" style="display: none;">Kaldır</button>
                                </div>
                            </div>
                            <div id="logo-url-container" style="display: none; margin-top: 10px;">
                                <input type="url" id="logo-url-input" class="form-input" placeholder="https://example.com/logo.jpg">
                            </div>
                        </div>
                        <div class="image-uploader">
                            <label class="form-label">Dükkan Banner (Kapak Resmi)</label>
                            <div style="margin-bottom: 10px;">
                                <label style="margin-right: 20px; cursor: pointer;">
                                    <input type="radio" name="banner-option" value="file" id="banner-option-file" checked> Dosya Seç
                                </label>
                                <label style="cursor: pointer;">
                                    <input type="radio" name="banner-option" value="url" id="banner-option-url"> URL Gir
                                </label>
                            </div>
                            <img src="" alt="Banner" id="banner-preview" class="banner-preview">
                            <div id="banner-file-container">
                                <input type="file" id="banner-upload" class="file-input">
                                <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                                    <label for="banner-upload" class="btn btn-secondary btn-sm">Resim Seç</label>
                                    <button type="button" id="remove-banner-btn" class="btn btn-secondary btn-sm" style="display: none;">Kaldır</button>
                                </div>
                            </div>
                            <div id="banner-url-container" style="display: none; margin-top: 10px;">
                                <input type="url" id="banner-url-input" class="form-input" placeholder="https://example.com/banner.jpg">
                            </div>
                        </div>
                    </div>

                    <hr class="divider">

                    <div class="form-group">
                        <label for="seller-fullname" class="form-label">Dükkan Sahibi Adı Soyadı</label>
                        <input type="text" id="seller-fullname" class="form-input" required>
                    </div>

                    <div class="form-group">
                        <label for="seller-email" class="form-label">E-posta Adresi</label>
                        <input type="email" id="seller-email" class="form-input" required>
                    </div>

                    <div class="form-group">
                        <label for="shop-name" class="form-label">Dükkan Adı</label>
                        <input type="text" id="shop-name" class="form-input" value="Ayşe'nin Mutfağı" required>
                    </div>
                    <div class="form-group">
                        <label for="shop-description" class="form-label">Dükkan Açıklaması (Alıcılar görecek)</label>
                        <textarea id="shop-description" class="form-input" rows="3">Zeytinyağlılar ve Ev Yapımı Mantı</textarea>
                    </div>

                    <hr class="divider">
                    
                    <div class="form-row"> 
                        <div class="form-group">
                            <label for="shop-location" class="form-label">Konum (İlçe)</label>
                            <input type="text" id="shop-location" class="form-input" value="Kadıköy">
                        </div>
                        <div class="form-group">
                            <label for="shop-hours" class="form-label">Çalışma Saatleri</label>
                            <input type="text" id="shop-hours" class="form-input" value="Hafta içi 09:00 - 21:00">
                        </div>
                    </div>

                    <!-- Teslimat Yarıçapı -->
                    <div class="form-group" style="margin-top: 0.5rem;">
                        <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                            📍 Teslimat Yarıçapı
                        </label>
                        <p class="text-muted" style="font-size: 0.85rem; margin-bottom: 1rem;">
                            Müşterilerinizin sizi görebileceği maksimum mesafeyi belirleyin. <strong>0 = Sınırsız</strong> (Tüm Türkiye'ye açık)
                        </p>
                        <div style="background: var(--bg-color, #f8fafc); border: 1px solid var(--border-color, #e2e8f0); border-radius: 12px; padding: 1.5rem; position: relative;">
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                                <span id="radius-label" style="font-size: 1.5rem; font-weight: 800; color: var(--primary-color, #dc2626);">Sınırsız</span>
                                <span id="radius-badge" style="background: rgba(16, 185, 129, 0.15); color: #059669; font-size: 0.8rem; font-weight: 700; padding: 0.35rem 0.85rem; border-radius: 20px; letter-spacing: 0.3px;">TÜM TÜRKİYE</span>
                            </div>
                            <input type="range" id="delivery-radius" min="0" max="500" step="10" value="0" style="width: 100%; accent-color: var(--primary-color, #dc2626); height: 8px; cursor: pointer;">
                            <div style="display: flex; justify-content: space-between; margin-top: 0.5rem;">
                                <span style="font-size: 0.75rem; color: #94a3b8;">0 (Sınırsız)</span>
                                <span style="font-size: 0.75rem; color: #94a3b8;">250 km</span>
                                <span style="font-size: 0.75rem; color: #94a3b8;">500 km</span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group" style="margin-top: 1rem;">
                        <label class="form-check" style="display: flex; align-items: flex-start; gap: 0.5rem; cursor: pointer;">
                            <input type="checkbox" id="pickup-enabled" checked style="margin-top: 0.2rem;">
                            <span><strong>Gel Al</strong> siparişlerini kabul et — müşteriler siparişi restorandan teslim alabilir (veritabanında saklanır).</span>
                        </label>
                    </div>

                    <div class="form-group" style="margin-top: 0.75rem;">
                        <label class="form-check" style="display: flex; align-items: flex-start; gap: 0.5rem; cursor: pointer;">
                            <input type="checkbox" id="uzak-mesafe-enabled" style="margin-top: 0.2rem;">
                            <span><strong>Uzak Mesafe Kargo</strong> — zeytinyağı, kuruyemiş gibi ürünleri kargo ile Türkiye geneline gönder. Açıkken menüde "Uzak Mesafe" ürün ekleyebilirsin.</span>
                        </label>
                    </div>
                    
                    <button type="submit" class="btn btn-primary">Profili Güncelle</button>
                    
                    <hr class="divider" style="margin: 2rem 0 1rem;">
                    <div class="form-group">
                        <h4 style="margin-bottom: 0.5rem; color: #c0392b;">Hesabı Sil</h4>
                        <p class="text-muted" style="margin-bottom: 0.75rem; font-size: 0.9rem;">
                            Bu işlem geri alınamaz. Satıcı hesabınız pasif hale getirilir ve tekrar giriş yapamazsınız.
                        </p>
                        <button type="button" class="btn btn-outline-danger" id="btn-delete-account">
                            Hesabımı Kalıcı Olarak Sil
                        </button>
                    </div>
                </form>

            </div>
        </div>

    </main>
</div>
<script>
(function() {
    async function doDeleteAccount() {
        var confirmed = await window.showConfirm('Hesabınızı kalıcı olarak silmek istediğinize emin misiniz? Bu işlem geri alınamaz.');
        if (!confirmed) return;
        var baseUrl = (typeof window.getBaseUrl === 'function' ? window.getBaseUrl() : '') || '';
        fetch(baseUrl + '/api/auth/delete-account', { method: 'DELETE', credentials: 'include' })
            .then(function(r) { return r.json().catch(function() { return {}; }).then(function(data) {
                if (r.ok && data.success) {
                    alert('Hesabınız silindi. Hoşçakalın.');
                    try { localStorage.clear(); sessionStorage.clear(); } catch (e) {}
                    window.location.href = baseUrl || '/';
                } else {
                    alert('Hesap silinemedi: ' + (data.message || r.status));
                }
            }); })
            .catch(function() { alert('Hesap silinirken bir hata oluştu.'); });
    }
    window.deleteMyAccount = doDeleteAccount;
    document.addEventListener('DOMContentLoaded', function() {
        var btn = document.getElementById('btn-delete-account');
        if (btn) btn.addEventListener('click', doDeleteAccount);
    });
})();
</script>