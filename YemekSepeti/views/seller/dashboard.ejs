<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css">

<!-- Real-time order updates user ID -->
<% if (user && user.id) { %>
    <script>
        window.currentUserId = <%= user.id %>;
        window.sessionStorage.setItem('userId', '<%= user.id %>');
    </script>
<% } %>

<div class="panel-layout">
    
    <%- include('../partials/sidebar') %>

    <main class="panel-content">
        
        <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
            <div>
                <h1 class="panel-title" style="margin-bottom: 0.5rem;">Dashboard (Ana Panel)</h1>
                <p class="panel-subtitle" id="dashboard-subtitle" style="margin-bottom: 0;">Yükleniyor...</p>
            </div>
            <div class="shop-status-container">
                <button id="shop-status-btn" class="btn" style="display: none; font-weight: bold;"></button>
            </div>
        </div>

        <div class="stat-grid">
            <div class="card stat-card">
                <span class="stat-icon">🔔</span>
                <span class="stat-label">Yeni Sipariş</span>
                <strong class="stat-value" id="stat-new-orders">0</strong>
            </div>
            <div class="card stat-card">
                <span class="stat-icon">✅</span>
                <span class="stat-label">Tamamlanan</span>
                <strong class="stat-value" id="stat-completed">0</strong>
            </div>
            <div class="card stat-card">
                <span class="stat-icon">💰</span>
                <span class="stat-label">Bugünkü Kazanç</span>
                <strong class="stat-value" id="stat-earnings">0 TL</strong>
            </div>
            <div class="card stat-card">
                <span class="stat-icon">⭐</span>
                <span class="stat-label">Dükkan Puanı</span>
                <strong class="stat-value" id="stat-rating">0</strong>
            </div>
        </div>

        <div class="card" style="margin-top: 2rem;">
            <div class="card-content">
                <h3 class="checkout-card-title">Son Gelen Siparişler</h3>
                
                <div class="order-list" id="recent-orders-list">
                    <p style="text-align: center; padding: 2rem; color: #666;">Yükleniyor...</p>
                </div>
            </div>
        </div>

    </main>
</div>