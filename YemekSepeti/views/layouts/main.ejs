<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Ev Lezzetleri</title>
    
    <base href="/">

    <script>
        (function() {
            try {
                const savedTheme = localStorage.getItem('ys-theme');
                const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                const initialTheme = savedTheme || (prefersDark ? 'dark' : 'light');
                document.documentElement.setAttribute('data-theme', initialTheme);
            } catch (err) {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="stylesheet" href="/assets/css/layout.css">
    <link rel="stylesheet" href="/assets/css/components.css">
    <link rel="stylesheet" href="/assets/css/responsive.css">
    <link rel="stylesheet" href="/assets/css/pages/floating-cart.css">
    <link rel="manifest" href="/manifest.json" id="app-manifest">
    
    <% if (typeof pageCss !== 'undefined' && pageCss) { %>
        <link rel="stylesheet" href="/assets/css/pages/<%= pageCss %>">
    <% } %>
</head>
<body class="bg-color">
    <script>
        window.__userId = '<%= typeof user !== "undefined" && user && user.id ? user.id : "" %>';
        window.__userRole = '<%= typeof user !== "undefined" && user && user.role ? user.role : "" %>';
    </script>
    <%- include('../partials/header') %>

    <main>
        <%- body %>
    </main>

    <%- include('../partials/footer') %>

    <script src="/assets/js/modules/modal-utils.js"></script>
    <script src="/assets/js/api.js"></script>
    <script src="/assets/js/main.js"></script>
    <script src="/assets/js/modules/header.js"></script>
    <script src="/assets/js/modules/notifications.js"></script>
    <script src="/assets/js/modules/cart.js"></script>
    <script src="/assets/js/modules/floating-cart.js"></script>
    <script src="/assets/js/modules/scroll-to-top.js"></script>

    <% if (typeof pageJs !== 'undefined' && pageJs) { %>
        <script src="/assets/js/modules/<%= pageJs %>"></script>
    <% } %>

    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js').catch(function() {});
        }
        (function(){ var m=document.getElementById('app-manifest'); if(m){ m.onerror=function(){ m.remove(); }; } })();
        window.addEventListener('online', function() {
            var el = document.getElementById('offline-banner');
            if (el) el.style.display = 'none';
        });
        window.addEventListener('offline', function() {
            var el = document.getElementById('offline-banner');
            if (el) { el.style.display = 'block'; } else {
                var b = document.createElement('div');
                b.id = 'offline-banner';
                b.setAttribute('role', 'alert');
                b.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#e74c3c;color:#fff;text-align:center;padding:8px;z-index:99999;font-size:0.9rem;';
                b.textContent = 'Çevrimdışısınız. İnternet bağlantınızı kontrol edin.';
                document.body.appendChild(b);
            }
        });
        if (!navigator.onLine) {
            window.addEventListener('DOMContentLoaded', function() {
                var b = document.createElement('div');
                b.id = 'offline-banner';
                b.setAttribute('role', 'alert');
                b.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#e74c3c;color:#fff;text-align:center;padding:8px;z-index:99999;font-size:0.9rem;';
                b.textContent = 'Çevrimdışısınız. İnternet bağlantınızı kontrol edin.';
                document.body.appendChild(b);
            });
        }
    </script>
    <!-- Socket.IO Client Library - Real-time Order Updates -->
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (window.location.pathname.includes('/seller') && typeof initializeSellerRealTimeUpdates === 'function') {
                setTimeout(initializeSellerRealTimeUpdates, 100);
            }
            if (window.location.pathname.includes('/courier') && typeof connectCourierSocketWhenReady === 'function') {
                setTimeout(connectCourierSocketWhenReady, 100);
            }
        });
    </script>

</body>
</html>