<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Ev Lezzetleri</title>
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/favicon.png">
    
    <base href="/">

    <script>
        (function() {
            try {
                const savedTheme = localStorage.getItem('ys-theme');
                const initialTheme = savedTheme || 'light';
                document.documentElement.setAttribute('data-theme', initialTheme);
            } catch (err) {
                document.documentElement.setAttribute('data-theme', 'light');
            }
        })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/assets/css/main.css">
    <link rel="stylesheet" href="/assets/css/layout.css?v=20260410-overlayfix">
    <link rel="stylesheet" href="/assets/css/components.css">
    <link rel="stylesheet" href="/assets/css/responsive.css?v=20260629-mobilefix1">
    <link rel="stylesheet" href="/assets/css/pages/floating-cart.css">
    <link rel="stylesheet" href="/assets/css/pages/loading.css">
    <link rel="manifest" href="/manifest.json" id="app-manifest">
    
    <% if (typeof pageCss !== 'undefined' && pageCss) { %>
        <link rel="stylesheet" href="/assets/css/pages/<%= pageCss %>">
    <% } %>
</head>
<body class="bg-color">
    <script>
        window.__userId = '<%= typeof user !== "undefined" && user && user.id ? user.id : "" %>';
        window.__userRole = '<%= typeof user !== "undefined" && user && user.role ? user.role : "" %>';
    </script>
    <!-- Global Yükleme Overlay -->
    <div id="ys-loading-overlay" role="status" aria-live="polite" aria-label="Yükleniyor">
        <div class="ys-spinner" aria-hidden="true"></div>
        <div class="ys-loading-text">Yükleniyor...</div>
    </div>

    <!-- Toast Bildirimleri -->
    <div id="ys-toast-container" aria-live="polite" aria-atomic="false"></div>

    <!-- Oturum Zaman Aşımı Uyarısı -->
    <div id="ys-session-warning-backdrop"></div>
    <div id="ys-session-warning" role="dialog" aria-modal="true" aria-labelledby="ys-session-warning-title">
        <div class="ys-session-warning-icon">⏳</div>
        <div class="ys-session-warning-title" id="ys-session-warning-title">Oturum Süreniz Dolmak Üzere</div>
        <div class="ys-session-warning-msg">Güvenliğiniz için oturumunuz otomatik kapatılacak.</div>
        <div class="ys-session-warning-countdown" id="ys-session-countdown" aria-label="Kalan süre">05:00</div>
        <div class="ys-session-warning-actions">
            <button class="ys-session-btn ys-session-btn-extend" id="ys-session-extend-btn">Oturumu Uzat</button>
            <button class="ys-session-btn ys-session-btn-logout" id="ys-session-logout-btn">Çıkış Yap</button>
        </div>
    </div>

    <%- include('../partials/header') %>
    <% if (typeof enableDeliveryModal === 'undefined' || enableDeliveryModal) { %>
    <%- include('../partials/delivery-area-modal') %>
    <% } %>

    <main class="ys-page-fade-in">
        <%- body %>
    </main>

    <%- include('../partials/footer') %>

    <!-- Socket.IO: page modüllerinden önce yüklenmeli -->
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <script>
        (function ensureSocketIoClientLoaded() {
            if (typeof window.io !== 'undefined') return;
            var script = document.createElement('script');
            script.src = '/socket.io/socket.io.js';
            document.head.appendChild(script);
        })();
    </script>
    <script src="/assets/js/modules/no-autofill.js?v=20260702-autofill1"></script>
    <script src="/assets/js/modules/ys-ui.js?v=20260602-security1"></script>
    <script src="/assets/js/modules/socket-manager.js?v=20260509-rtfix2"></script>
    <script src="/assets/js/modules/modal-utils.js?v=20260324-rtfix3"></script>
    <script src="/assets/js/api.js?v=20260324-rtfix3"></script>
    <script src="/assets/js/main.js?v=20260324-rtfix3"></script>
    <script src="/assets/js/modules/header.js?v=20260324-rtfix3"></script>
    <script src="/assets/js/modules/notifications.js?v=20260510-sockfix1"></script>
    <script src="/assets/js/modules/push-subscribe.js?v=20260511-pushv1"></script>
    <script src="/assets/js/modules/cart.js?v=20260324-rtfix3"></script>
    <script src="/assets/js/modules/floating-cart.js?v=20260324-rtfix3"></script>
    <script src="/assets/js/modules/scroll-to-top.js?v=20260324-rtfix3"></script>
    <% if (typeof enableDeliveryModal === 'undefined' || enableDeliveryModal) { %>
    <script src="/assets/js/modules/delivery-area-modal.js?v=20260410-panelfix1"></script>
    <% } %>

    <script src="/assets/js/modules/ys-select.js"></script>

    <% if (typeof pageJs !== 'undefined' && (pageJs === 'courier.js' || pageJs === 'seller-profile.js')) { %>
        <script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
    <% } %>
    <% if (typeof pageJs !== 'undefined' && pageJs) { %>
        <script src="/assets/js/modules/<%= pageJs %>?v=20260629-reviewdel1"></script>
    <% } %>

    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then(function(registrations) {
                registrations.forEach(function(reg) { reg.unregister(); });
            }).catch(function() {});
        }
        (function(){ var m=document.getElementById('app-manifest'); if(m){ m.onerror=function(){ m.remove(); }; } })();
        window.addEventListener('online', function() {
            var el = document.getElementById('offline-banner');
            if (el) el.style.display = 'none';
        });
        window.addEventListener('offline', function() {
            var el = document.getElementById('offline-banner');
            if (el) { el.style.display = 'block'; } else {
                var b = document.createElement('div');
                b.id = 'offline-banner';
                b.setAttribute('role', 'alert');
                b.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#e74c3c;color:#fff;text-align:center;padding:8px;z-index:99999;font-size:0.9rem;';
                b.textContent = 'Çevrimdışısınız. İnternet bağlantınızı kontrol edin.';
                document.body.appendChild(b);
            }
        });
        if (!navigator.onLine) {
            window.addEventListener('DOMContentLoaded', function() {
                var b = document.createElement('div');
                b.id = 'offline-banner';
                b.setAttribute('role', 'alert');
                b.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#e74c3c;color:#fff;text-align:center;padding:8px;z-index:99999;font-size:0.9rem;';
                b.textContent = 'Çevrimdışısınız. İnternet bağlantınızı kontrol edin.';
                document.body.appendChild(b);
            });
        }
    </script>


</body>
</html>