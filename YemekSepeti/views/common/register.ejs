<div class="auth-page"> 
    <div class="auth-container">
        
        <div class="card auth-card">
            <div class="card-content">
                <h1 class="card-title" style="text-align: center;">Hesap Oluştur</h1>
                <p class="text-center auth-subtext">Aramıza katılmak için bilgilerinizi girin.</p>
                
                <form id="register-form" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="fullname" class="form-label">Ad Soyad</label>
                        <input type="text" id="fullname" class="form-input" placeholder="Adınız Soyadınız" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="email" class="form-label">E-posta Adresi</label>
                        <input type="email" id="email" class="form-input" placeholder="ornek@mail.com" required>
                    </div>

                    <div class="form-group">
                        <label for="password" class="form-label">Şifre</label>
                        <input type="password" id="password" class="form-input" placeholder="En az 6 karakter" required>
                    </div>

                    <div class="form-group">
                        <label for="confirm-password" class="form-label">Şifre Tekrar</label>
                        <input type="password" id="confirm-password" class="form-input" placeholder="Şifrenizi doğrulayın" required>
                    </div>

                    <hr class="divider"> 
                    
                    <div class="form-group">
                        <label class="form-label">Hesap Türü Seçin:</label>
                        <div class="role-selector"> 
                            <div class="form-check form-check-radio">
                                <input type="radio" id="role-buyer" name="user-role" value="buyer" checked>
                                <label for="role-buyer">
                                    <span class="icon">🛒</span> 
                                    <strong>Alıcıyım</strong> 
                                    <span>(Yemek sipariş vermek istiyorum)</span>
                                </label>
                            </div>
                            
                            <div class="form-check form-check-radio">
                                <input type="radio" id="role-seller" name="user-role" value="seller">
                                <label for="role-seller">
                                    <span class="icon">🍲</span> 
                                    <strong>Satıcıyım</strong> 
                                    <span>(Yemek satmak istiyorum)</span>
                                </label>
                            </div>
                            
                            <div class="form-check form-check-radio">
                                <input type="radio" id="role-courier" name="user-role" value="courier">
                                <label for="role-courier">
                                    <span class="icon">🚚</span> 
                                    <strong>Kuryeyim</strong> 
                                    <span>(Sipariş teslimatı yapmak istiyorum)</span>
                                </label>
                            </div>
                        </div>
                        <p class="text-muted" style="margin-top: 8px; font-size: 0.9rem;">Satıcı ve kurye seçeneklerinde e-posta doğrulamasından sonra belgeleriniz istenecektir.</p>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" id="terms" required>
                            <label for="terms"><a href="/terms">Kullanım Koşulları</a>'nı okudum ve kabul ediyorum.</label>
                        </div>
                    </div>
                    
                    <button type="submit" class="btn btn-primary btn-full"> 
                        Kayıt Ol
                    </button>
                </form>

                <!-- Email Doğrulama Ekranı -->
                <div id="verification-section" style="display: none;">
                    <h2 class="card-title text-center">Email Doğrulama</h2>
                    <p class="text-center auth-subtext">Email adresinize gönderilen 6 haneli kodu girin.</p>
                    
                    <!-- Geri Sayım Sayacı -->
                    <div id="countdown-container" style="display: flex; flex-direction: column; align-items: center; margin: 18px 0 10px;">
                        <div style="position: relative; width: 80px; height: 80px;">
                            <svg width="80" height="80" viewBox="0 0 80 80" style="transform: rotate(-90deg);">
                                <circle cx="40" cy="40" r="34" fill="none" stroke="#f0f0f0" stroke-width="6"/>
                                <circle id="countdown-ring" cx="40" cy="40" r="34" fill="none" stroke="#e63946" stroke-width="6"
                                    stroke-dasharray="213.628" stroke-dashoffset="0"
                                    stroke-linecap="round" style="transition: stroke-dashoffset 1s linear, stroke 0.3s;"/>
                            </svg>
                            <div id="countdown-text" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 1.15rem; font-weight: 700; color: #e63946; font-family: 'Inter', monospace;">
                                5:00
                            </div>
                        </div>
                        <p id="countdown-label" style="margin-top: 8px; font-size: 0.85rem; color: #888;">Kodun geçerlilik süresi</p>
                    </div>
                    
                    <!-- Süre Doldu Mesajı -->
                    <div id="code-expired-msg" style="display: none; text-align: center; padding: 12px; background: #FEE2E2; color: #DC2626; border-radius: 8px; margin-bottom: 12px; font-weight: 600; font-size: 0.95rem;">
                        ⏰ Kodun süresi doldu! Lütfen yeni kod isteyin.
                    </div>

                    <form id="verify-email-form">
                        <div class="form-group">
                            <label for="verification-code" class="form-label">Doğrulama Kodu</label>
                            <input type="text" id="verification-code" class="form-input" placeholder="123456" maxlength="6" required>
                        </div>
                        <button type="submit" class="btn btn-primary btn-full" id="verify-submit-btn">Doğrula</button>
                        <button type="button" id="resend-code" class="btn btn-secondary btn-full" style="margin-top: 10px;">Kodu Tekrar Gönder</button>
                    </form>
                </div>

                <div class="auth-footer-link">
                    <p>Zaten bir hesabın var mı? <a href="/login">Giriş Yap</a></p>
                </div>

            </div>
        </div>

    </div>
</div>