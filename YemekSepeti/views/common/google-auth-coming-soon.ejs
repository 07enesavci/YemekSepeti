<div class="auth-page">
    <div class="auth-container">
        <div class="card auth-card">
            <div class="card-content">
                <h1 class="card-title text-center"><%= statusTitle %></h1>
                <p class="text-center auth-subtext">Google API entegrasyonu bu proje icin henuz aktif degil.</p>

                <div class="google-status-panel">
                    <p class="google-status-title">Bilgilendirme</p>
                    <p class="google-status-text">
                        Google ile giris ve kayit ozelligi hazirlaniyor. Google OAuth ayarlari tamamlandiginda bu buton otomatik olarak aktif calisacak.
                    </p>
                </div>

                <a href="<%= backUrl %>" class="btn btn-primary btn-full"><%= backButtonText %></a>
            </div>
        </div>
    </div>
</div>
