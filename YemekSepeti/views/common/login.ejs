<div class="auth-page">
    <div class="auth-container">
        
        <div class="card auth-card">
            <div class="card-content">
                <h1 class="card-title text-center">Giriş Yap</h1>
                <p class="text-center auth-subtext">Lezzet dünyamıza tekrar hoş geldin!</p>
                
                <form id="login-form">
                    
                    <div class="form-group">
                        <label for="email" class="form-label">E-posta Adresi</label>
                        <input type="email" id="email" class="form-input" placeholder="ornek@mail.com" required>
                    </div>
                    
                    <div class="form-group">
                        <label for="password" class="form-label">Şifre</label>
                        <input type="password" id="password" class="form-input" placeholder="••••••••" required>
                    </div>

                    <div class="form-group-inline space-between">
                        <div class="form-check">
                            <input type="checkbox" id="remember-me">
                            <label for="remember-me">Beni Hatırla</label>
                        </div>
                        <a href="/forgot-password" class="form-link">Şifremi Unuttum</a>
                    </div>
                    
                    <button type="submit" class="btn btn-primary btn-full"> Giriş Yap</button>

                    <div class="auth-divider" role="separator" aria-label="Alternatif giriş seçenekleri">
                        <span>veya</span>
                    </div>

                    <a href="/api/auth/google/login" class="btn btn-google btn-full" aria-label="Google ile giriş yap">
                        <span class="google-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" focusable="false">
                                <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.3-1.5 3.9-5.5 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.9 0 3.2.8 3.9 1.5l2.7-2.6C16.9 3.4 14.7 2.5 12 2.5a9.5 9.5 0 1 0 0 19c5.5 0 9.1-3.8 9.1-9.2 0-.6-.1-1.1-.2-1.6H12z"/>
                                <path fill="#34A853" d="M3.5 7.6l3.2 2.3C7.6 8.1 9.6 6.6 12 6.6c1.9 0 3.2.8 3.9 1.5l2.7-2.6C16.9 3.9 14.7 3 12 3 8.3 3 5.1 5.1 3.5 7.6z"/>
                                <path fill="#FBBC05" d="M12 21c2.6 0 4.8-.8 6.4-2.2l-3-2.4c-.8.6-1.9 1-3.3 1-2.4 0-4.4-1.6-5.1-3.8L3.8 16c1.6 3.1 4.8 5 8.2 5z"/>
                                <path fill="#4285F4" d="M21.1 12.3c0-.7-.1-1.3-.2-1.9H12v3.9h5.1c-.2 1.1-.9 2-1.8 2.6l3 2.4c1.8-1.7 2.8-4.2 2.8-7z"/>
                            </svg>
                        </span>
                        Google ile Giriş Yap
                    </a>
                </form>

                <!-- 2FA Doğrulama Ekranı -->
                <div id="2fa-section" style="display: none;">
                    <h2 class="card-title text-center">İki Faktörlü Kimlik Doğrulama</h2>
                    <p class="text-center auth-subtext">Email adresinize gönderilen 6 haneli kodu girin.</p>
                    <form id="verify-2fa-form">
                        <div class="form-group">
                            <label for="2fa-code" class="form-label">Doğrulama Kodu</label>
                            <input type="text" id="2fa-code" class="form-input" placeholder="123456" maxlength="6" required>
                        </div>
                        <button type="submit" class="btn btn-primary btn-full">Doğrula</button>
                        <button type="button" id="resend-2fa-code" class="btn btn-secondary btn-full" style="margin-top: 10px;">Kodu Tekrar Gönder</button>
                    </form>
                </div>

                <div class="auth-footer-link">
                    <p>Hesabın yok mu? <a href="/register">Hemen Kayıt Ol</a></p>
                </div>

            </div>
        </div>

    </div>
</div>