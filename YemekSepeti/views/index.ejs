<section class="hero-section" id="hero-section">
    <!-- Hero Background Slider - Veritabanından yüklenecek -->
    <div class="hero-background-slider" id="hero-background-slider"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content container">
        <h1>Mahallenizdeki En Lezzetli Ev Yemekleri</h1>
        <p>Güvenilir aşçılardan, taze ve sağlıklı ev yemeklerini keşfedin.</p>
        <div class="hero-search hero-search-with-history">
            <input type="text" id="hero-search-input" class="form-input" placeholder="Yemek veya mutfak arayın..." autocomplete="off" aria-label="Yemek veya mutfak ara">
            <button type="button" id="hero-search-button" class="btn btn-primary" style="display: inline-flex; align-items: center; justify-content: center;" aria-label="Ara">Bul</button>
            <div id="search-history-dropdown" class="search-history-dropdown" role="listbox" aria-label="Son aramalar" style="display: none;"></div>
        </div>
    </div>
</section>

<section class="container section-padding" style="background: transparent;">
    <!-- Fırsatlar/Kuponlar Banner -->
    <div class="promotions-banner" id="promotions-banner" title="Kuponlarımı gör" style="cursor: pointer;">
        <div class="promotions-wrapper">
            <div class="promotions-track" id="promotions-track">
                <!-- JS tarafından doldurulur (home.js initPromotionsBanner) -->
            </div>
        </div>
    </div>
    
    <div class="restaurants-section-header">
        <h2 class="section-title">Tüm Restoranlar</h2>
        <p class="restaurants-section-desc">Mahallenizdeki en lezzetli ev yemeklerini keşfedin</p>
    </div>
    
    <!-- Hızlı Filtreler -->
    <div class="quick-filters">
        <button type="button" class="quick-filter-btn active" data-filter="all">🍽️ Tümü</button>
        <button type="button" class="quick-filter-btn" data-filter="deals">🔥 Fırsatlar</button>
        <button type="button" class="quick-filter-btn" data-filter="new">✨ Yeni Restoranlar</button>
        <button type="button" class="quick-filter-btn" data-filter="top_rated">⭐ En Çok Değerlendirilen</button>
        <button type="button" class="quick-filter-btn" data-filter="uzak_mesafe">📦 Uzak Mesafe Kargo</button>
    </div>
    
    <!-- Filtreleme ve Restoranlar Layout -->
    <div class="restaurants-layout">
        <!-- Sol Taraf: Filtreleme Paneli -->
        <aside class="filters-sidebar">
            <div class="card">
                <div class="card-content">
                    <h3 class="card-title">Filtrele</h3>
                    
                    <!-- Yıldız Filtresi -->
                    <div class="form-group">
                        <label class="form-label">Puana Göre</label>
                        <div class="form-check">
                            <input type="checkbox" id="filter-rating-5" class="filter-rating" value="5">
                            <label for="filter-rating-5">⭐⭐⭐⭐⭐ 5 Yıldız</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" id="filter-rating-4" class="filter-rating" value="4">
                            <label for="filter-rating-4">⭐⭐⭐⭐ 4 ve üzeri</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" id="filter-rating-3" class="filter-rating" value="3">
                            <label for="filter-rating-3">⭐⭐⭐ 3 ve üzeri</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" id="filter-rating-2" class="filter-rating" value="2">
                            <label for="filter-rating-2">⭐⭐ 2 ve üzeri</label>
                        </div>
                    </div>
                    
                    <!-- Minimum Sepet Tutarı -->
                    <div class="form-group">
                        <label for="filter-min-order" class="form-label">Minimum Sepet Tutarı</label>
                        <select id="filter-min-order" class="form-input">
                            <option value="">Tümü</option>
                            <option value="0">0 TL</option>
                            <option value="50">50 TL</option>
                            <option value="100">100 TL</option>
                            <option value="150">150 TL</option>
                            <option value="200">200 TL</option>
                            <option value="300">300 TL</option>
                        </select>
                    </div>
                    
                    <!-- Konum Filtresi -->
                    <div class="form-group">
                        <label for="filter-location" class="form-label">Konum</label>
                        <input type="text" id="filter-location" class="form-input" placeholder="İlçe / Mahalle ara...">
                    </div>
                    
                    <!-- Sadece Açık Restoranlar -->
                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" id="filter-only-open">
                            <label for="filter-only-open">🟢 Sadece Açık Restoranlar</label>
                        </div>
                    </div>
                    
                    <!-- Filtreleri Temizle -->
                    <button type="button" id="clear-filters" class="btn btn-secondary btn-full" style="margin-top: 1rem;">Filtreleri Temizle</button>
                </div>
            </div>
        </aside>
        
        <!-- Sağ Taraf: Restoranlar -->
        <div class="restaurants-content">
            <div class="results-header" id="results-header" style="display: none;">
                <span><strong id="results-count">0</strong> restoran bulundu</span>
            </div>
            <div class="featured-grid" id="restaurants-container">
            </div>
        </div>
    </div>
</section>