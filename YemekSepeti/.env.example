# ============================================
# VERİTABANI BAĞLANTI AYARLARI
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=kullanici_adi
DB_PASSWORD=sifre
DB_NAME=veritabani_adi
DB_SSL=false
# DB_CA_PATH=/path/to/ca.pem

# ============================================
# SESSION AYARLARI (güçlü rastgele değer kullanın)
# ============================================
SESSION_SECRET=buraya-uzun-rastgele-bir-anahtar-yazin

# ============================================
# JWT AYARLARI
# ============================================
JWT_SECRET=buraya-jwt-icin-uzun-rastgele-anahtar

# ============================================
# NODE ENVIRONMENT (development | production)
# ============================================
NODE_ENV=development

# ============================================
# MYSQL SESSION STORE (true | false)
# ============================================
USE_MYSQL_SESSION=false

# ============================================
# EMAIL AYARLARI (şifre sıfırlama vb.)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=uygulama-sifresi
EMAIL_FROM=noreply@siteadi.com
EMAIL_SECURE=false

# ============================================
# Opsiyonel: BASE_URL (şifre sıfırlama linkleri için)
# ============================================
# BASE_URL=https://evlezzetleri.site

# ============================================
# IYZICO SANDBOX AYARLARI
# ============================================
IYZICO_API_KEY=sandbox-xxxx
IYZICO_SECRET_KEY=sandbox-yyyy
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
