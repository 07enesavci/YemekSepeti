# ============================================
# VERİTABANI BAĞLANTI AYARLARI (TiDB Cloud)
# ============================================
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL=true
# CA Sertifika Yolu (Opsiyonel - eğer CA sertifikası varsa)
# DB_CA_PATH=<CA_PATH>

BUYER_DOMAIN=evlezzetleri.site
PARTNER_DOMAIN=partner.evlezzetleri.site
ADMIN_DOMAIN=admin.evlezzetleri.site

# ============================================
# SESSION AYARLARI
# ============================================
SESSION_SECRET=gizli-anahtar-degistirin-production-icin

# ============================================
# JWT AYARLARI
# ============================================
JWT_SECRET=jwt-secret-key-degistirin-production-icin

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=production

# Açılışta tüm satıcıları onaylı say (is_active/is_open). Kapatmak için false yapın.
APPROVE_ALL_SELLERS_ON_STARTUP=true

# ============================================
# MYSQL SESSION STORE
# ============================================
USE_MYSQL_SESSION=true

# ============================================
# EMAIL AYARLARI
# ============================================
# Gmail için örnek:
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_SECURE=false

# ============================================
# IYZICO SANDBOX AYARLARI
# ============================================
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com


# Google OAuth (hazır olunca doldurun)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
 GOOGLE_REDIRECT_URI=https://evlezzetleri.site/api/auth/google/callback