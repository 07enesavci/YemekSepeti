<div class="container section-padding">
    <h1 class="section-title">Satıcıları Keşfet</h1>

    <div class="search-layout">
        
        <aside class="search-filters">
            <div class="card">
                <div class="card-content">
                    <h3 class="card-title">Filtrele</h3>
                    
                    <div class="form-group">
                        <label for="location" class="form-label">Konum</label>
                        <input type="text" id="location" class="form-input" placeholder="İlçe / Mahalle ara...">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Puana Göre</label>
                        <div class="form-check">
                            <input type="checkbox" id="rate-4">
                            <label for="rate-4">⭐ 4 ve üzeri</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" id="rate-3">
                            <label for="rate-3">⭐ 3 ve üzeri</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mutfak Türü</label>
                        <div class="form-check">
                            <input type="checkbox" id="cuisine-tr">
                            <label for="cuisine-tr">Türk Mutfağı</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" id="cuisine-it">
                            <label for="cuisine-it">İtalyan</label>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" id="cuisine-vegan">
                            <label for="cuisine-vegan">Vegan</label>
                        </div>
                    </div>

                    <button class="btn btn-primary btn-full">Filtreleri Uygula</button>
                </div>
            </div>
        </aside>

        <div class="search-results">
            
            <div class="results-header">
                <span><strong>12</strong> satıcı bulundu</span>
                <select class="form-input" id="sort-by" style="width: 200px;">
                    <option value="default">Varsayılan Sıralama</option>
                    <option value="rating">Puana Göre</option>
                    <option value="distance">Yakınlığa Göre</option>
                </select>
            </div>

            <div class="featured-grid" id="search-results-list">
                </div>
        </div>

    </div>
</div>