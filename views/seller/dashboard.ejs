<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css">

<div class="panel-layout">
    
    <%- include('../partials/sidebar') %>

    <main class="panel-content">
        
        <h1 class="panel-title">Dashboard (Ana Panel)</h1>
        <p class="panel-subtitle">Hoş geldin, Ayşe'nin Mutfağı! İşletmenizin anlık durumu burada.</p>

        <div class="stat-grid">
            <div class="card stat-card">
                <span class="stat-icon">🔔</span>
                <span class="stat-label">Yeni Sipariş</span>
                <strong class="stat-value">3</strong>
            </div>
            <div class="card stat-card">
                <span class="stat-icon">✅</span>
                <span class="stat-label">Tamamlanan</span>
                <strong class="stat-value">12</strong>
            </div>
            <div class="card stat-card">
                <span class="stat-icon">💰</span>
                <span class="stat-label">Bugünkü Kazanç</span>
                <strong class="stat-value">680 TL</strong>
            </div>
            <div class="card stat-card">
                <span class="stat-icon">⭐</span>
                <span class="stat-label">Dükkan Puanı</span>
                <strong class="stat-value">4.9</strong>
            </div>
        </div>

        <div class="card" style="margin-top: 2rem;">
            <div class="card-content">
                <h3 class="checkout-card-title">Son Gelen Siparişler</h3>
                
                <div class="order-list">
                    <div class="order-list-item">
                        <div class="order-info">
                            <strong>#1052 - E*** S.</strong>
                            <span>2 x Ev Mantısı, 1 x Sütlaç</span>
                        </div>
                        <div class="order-status preparing">
                            Hazırlanıyor
                        </div>
                        <div class="order-price">
                            280.00 TL
                        </div>
                        <a href="/seller/orders" class="btn btn-secondary btn-sm">Detay</a>
                    </div>
                    
                    <div class="order-list-item">
                        <div class="order-info">
                            <strong>#1051 - A*** K.</strong>
                            <span>1 x Kuru Fasulye</span>
                        </div>
                        <div class="order-status delivered">
                            Teslim Edildi
                        </div>
                        <div class="order-price">
                            85.00 TL
                        </div>
                        <a href="/seller/orders" class="btn btn-secondary btn-sm">Detay</a>
                    </div>
                </div>
            </div>
        </div>

    </main>
</div>