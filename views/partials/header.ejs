<header class="site-header">
    <div class="header-content container">
        <a href="/" class="logo">Ev Lezzetleri</a>
        <nav class="main-nav">
            <ul> 	
                <li><a href="/" class="btn btn-secondary">Ana Sayfa</a></li>
                <li><a href="/buyer/search" class="btn btn-secondary">Satıcı Bul</a></li>
                
                <% if (user) { %>
                    <li>
                        <% if(user.role === 'buyer') { %>
                            <a href="/buyer/profile" class="btn btn-secondary">Profilim</a>
                        <% } else if(user.role === 'seller') { %>
                            <a href="/seller/dashboard" class="btn btn-secondary">Panelim</a>
                        <% } else if(user.role === 'courier') { %>
                            <a href="/courier/dashboard" class="btn btn-secondary">Panelim</a>
                        <% } else if(user.role === 'admin') { %>
                            <a href="/admin/users" class="btn btn-secondary">Admin</a>
                        <% } %>
                    </li>
                    <li><a href="/api/auth/logout" class="btn btn-secondary">Çıkış Yap</a></li> 
                <% } else { %>
                    <li><a href="/login" class="btn btn-secondary">Giriş Yap</a></li>
                    <li><a href="/register" class="btn btn-primary">Kayıt Ol</a></li>
                <% } %>
                
                <li style="position: relative;"> 
                    <a href="/buyer/cart" class="btn btn-primary">
                        Sepet (<span id="cart-count"><%= cartCount %></span>) 
                    </a>
                    <% if (notificationsCount > 0) { %>
                        <span class="notification-badge" style="
                            position: absolute; 
                            top: -8px; 
                            right: -8px; 
                            background: red; 
                            color: white; 
                            padding: 2px 6px; 
                            border-radius: 50%; 
                            font-size: 0.7rem; 
                            line-height: 1;">
                            <%= notificationsCount %>
                        </span>
                    <% } %>
                </li>

            </ul>
        </nav>
    </div>
</header>