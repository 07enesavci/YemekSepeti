<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css">
<div class="panel-layout">
    
    <%- include('../partials/sidebar') %>

    <main class="panel-content">
        
        <h1 class="panel-title">Profil ve Ayarlar</h1>
        
        <div class="card">
            <div class="card-content">
                
                <div id="status-message" style="padding: 10px; margin-bottom: 15px; border-radius: 4px; display: none; font-weight: bold;">
                    </div>

                <form id="courier-profile-form">
                    
                    <div class="form-group">
                        <label class="form-label">Müsaitlik Durumu</label>
                        <div class="role-selector">
                            <div class="form-check form-check-radio">
                                <input type="radio" id="status-online" name="courier-status" value="online" checked>
                                <label for="status-online" style="border-color: #4CAF50;">
                                    <strong style="color: #4CAF50;">Aktif (Görev Alabilir)</strong>
                                </label>
                            </div>
                            <div class="form-check form-check-radio">
                                <input type="radio" id="status-offline" name="courier-status" value="offline">
                                <label for="status-offline" style="border-color: #E74C3C;">
                                    <strong style="color: #E74C3C;">Pasif (Görev Alamaz)</strong>
                                </label>
                            </div>
                        </div>
                    </div>

                    <hr class="divider">

                    <div class="form-group">
                        <label for="courier-name" class="form-label">Ad Soyad</label>
                        <input type="text" id="courier-name" class="form-input" placeholder="Ad Soyad" value="<%= user && user.fullname ? user.fullname : '' %>" required>
                    </div>
                    <div class="form-group">
                        <label for="courier-phone" class="form-label">Telefon Numarası</label>
                        <input type="tel" id="courier-phone" class="form-input" value="<%= user && user.phone ? user.phone : '' %>" placeholder="Telefon Numarası">
                    </div>
                    <div class="form-group">
                        <label for="courier-vehicle" class="form-label">Araç Tipi</label>
                        <select id="courier-vehicle" class="form-input">
                            <option value="motorcycle" selected>Motorsiklet</option>
                            <option value="car">Araba</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary">Bilgileri Güncelle</button>

                    <hr class="divider" style="margin: 2rem 0 1rem;">
                    <div class="form-group">
                        <h4 style="margin-bottom: 0.5rem; color: #c0392b;">Hesabı Sil</h4>
                        <p class="text-muted" style="margin-bottom: 0.75rem; font-size: 0.9rem;">
                            Bu işlem geri alınamaz. Kurye hesabınız pasif hale getirilir ve tekrar giriş yapamazsınız.
                        </p>
                        <button type="button" class="btn btn-outline-danger" id="btn-delete-account">
                            Hesabımı Kalıcı Olarak Sil
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </main>
</div>
<script>
(function() {
    function doDeleteAccount() {
        if (!window.confirm('Hesabınızı kalıcı olarak silmek istediğinize emin misiniz? Bu işlem geri alınamaz.')) return;
        var baseUrl = (typeof window.getBaseUrl === 'function' ? window.getBaseUrl() : '') || '';
        fetch(baseUrl + '/api/auth/delete-account', { method: 'DELETE', credentials: 'include' })
            .then(function(r) { return r.json().catch(function() { return {}; }).then(function(data) {
                if (r.ok && data.success) {
                    alert('Hesabınız silindi. Hoşçakalın.');
                    try { localStorage.clear(); sessionStorage.clear(); } catch (e) {}
                    window.location.href = baseUrl || '/';
                } else {
                    alert('Hesap silinemedi: ' + (data.message || r.status));
                }
            }); })
            .catch(function() { alert('Hesap silinirken bir hata oluştu.'); });
    }
    window.deleteMyAccount = doDeleteAccount;
    document.addEventListener('DOMContentLoaded', function() {
        var btn = document.getElementById('btn-delete-account');
        if (btn) btn.addEventListener('click', doDeleteAccount);
    });
})();
</script>