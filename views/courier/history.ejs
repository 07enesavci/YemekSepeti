<link rel="stylesheet" href="/assets/css/pages/seller-dashboard.css">
<link rel="stylesheet" href="/assets/css/pages/courier-history.css">

<div class="panel-layout">
    
    <%- include('../partials/sidebar') %>

    <main class="panel-content">
        
        <h1 class="panel-title">Teslimat Geçmişi ve Kazançlar</h1>
        
        <div class="stat-grid">
            <div class="card stat-card">
                <span class="stat-icon">💰</span>
                <span class="stat-label">Toplam Bakiye</span>
                <strong class="stat-value">340.00 TL</strong>
            </div>
            <div class="card stat-card">
                <span class="stat-icon">✅</span>
                <span class="stat-label">Toplam Teslimat</span>
                <strong class="stat-value">28</strong>
            </div>
        </div>

        <div class="card" style="margin-top: 2rem;">
            <div class="card-content">
                <h3 class="checkout-card-title">Son İşlemler</h3>
                
                <div class="transaction-list">
                    
                    <div class="transaction-item">
                        <div class="transaction-icon income">
                            <span>+</span>
                        </div>
                        <div class="transaction-details">
                            <strong>#1052 Nolu Teslimat Kazancı</strong>
                            <span>12 Kasım 2025</span>
                        </div>
                        <div class="transaction-amount income">
                            +45.00 TL
                        </div>
                    </div>

                    <div class="transaction-item">
                        <div class="transaction-icon payout">
                            <span>-</span>
                        </div>
                        <div class="transaction-details">
                            <strong>Ödeme Çekildi (IBAN: ...5678)</strong>
                            <span>11 Kasım 2025</span>
                        </div>
                        <div class="transaction-amount payout">
                            -250.00 TL
                        </div>
                    </div>

                    <div class="transaction-item">
                        <div class="transaction-icon income">
                            <span>+</span>
                        </div>
                        <div class="transaction-details">
                            <strong>#1051 Nolu Teslimat Kazancı</strong>
                            <span>10 Kasım 2025</span>
                        </div>
                        <div class="transaction-amount income">
                            +25.00 TL
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </main>
</div>