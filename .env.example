# ===========================================
# E-POSTA (Kayıt doğrulama kodu için ZORUNLU)
# Bu değişkenler tanımlı değilse e-postalar GÖNDERİLMEZ (test modu).
# Arkadaşınız localde çalıştırıyorsa kendi .env dosyasında bunları doldurmalı.
# ===========================================
# Seçenek 1: Gmail (Uygulama şifresi kullanın, normal şifre çalışmaz)
# EMAIL_SERVICE=gmail
# EMAIL_USER=yourmail@gmail.com
# EMAIL_PASS=xxxx xxxx xxxx xxxx

# Seçenek 2: Kendi SMTP sunucunuz
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=no-reply@example.com
# EMAIL_PASS=yourpassword

# Opsiyonel
# EMAIL_FROM=no-reply@example.com
# EMAIL_FROM_NAME=Ev Lezzetleri

# ===========================================
# Veritabanı (projede kendi ayarlarınız olabilir)
# ===========================================
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=yemek_sepeti
